---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
---

<BaseLayout
  title="Page not found | z4j"
  description="The page you are looking for does not exist. Return to the z4j home page or browse features, engines, and frameworks."
  noindex={true}
>
  <section class="mx-auto flex min-h-[60vh] max-w-3xl flex-col items-center justify-center px-4 py-24 text-center md:px-6">
    <div class="mb-6 inline-flex size-16 items-center justify-center rounded-2xl bg-[var(--color-primary)]/10 text-[var(--color-primary)]">
      <Icon name="terminal" size={32} />
    </div>
    <p class="font-mono text-sm text-[var(--color-muted)]">404</p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight md:text-5xl">
      Page not found
    </h1>
    <p class="mt-4 max-w-xl text-lg text-[var(--color-muted)]">
      The page you are looking for does not exist or has moved. Try one of the links below.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a
        href="/"
        class="inline-flex items-center rounded-lg bg-[var(--color-primary)] px-5 py-2.5 text-sm font-semibold text-white hover:opacity-90 transition-opacity"
      >
        Back to home
      </a>
      <a
        href="/install"
        class="inline-flex items-center rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] px-5 py-2.5 text-sm font-semibold hover:border-[var(--color-primary)]/50 transition-colors"
      >
        Install z4j
      </a>
      <a
        href="https://z4j.dev"
        class="inline-flex items-center rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] px-5 py-2.5 text-sm font-semibold hover:border-[var(--color-primary)]/50 transition-colors"
      >
        Documentation
      </a>
    </div>
    <div class="mt-12 grid w-full gap-3 sm:grid-cols-3">
      <a href="/features" class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-4 text-left transition-all hover:border-[var(--color-primary)]/40">
        <p class="text-sm font-semibold">Features</p>
        <p class="mt-1 text-xs text-[var(--color-muted)]">12 platform capabilities in v1.0</p>
      </a>
      <a href="/engines" class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-4 text-left transition-all hover:border-[var(--color-primary)]/40">
        <p class="text-sm font-semibold">Engines</p>
        <p class="mt-1 text-xs text-[var(--color-muted)]">6 Python task queue adapters</p>
      </a>
      <a href="/pricing" class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-4 text-left transition-all hover:border-[var(--color-primary)]/40">
        <p class="text-sm font-semibold">Pricing</p>
        <p class="mt-1 text-xs text-[var(--color-muted)]">Free, open source, self-hosted</p>
      </a>
    </div>
  </section>
</BaseLayout>
