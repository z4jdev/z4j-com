---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/Section.astro";
import Card from "../../components/Card.astro";
import PageHero from "../../components/PageHero.astro";
import CTA from "../../components/CTA.astro";
import { FRAMEWORKS } from "../../data/frameworks";
---

<BaseLayout
  title="Django, Flask, FastAPI integrations | z4j"
  description="First-class adapters for Django, Flask, and FastAPI. Pick your framework and z4j handles task-queue integration, lifecycle wiring, and settings discovery for you."
  keywords={["Django task queue", "Flask Celery", "FastAPI arq", "framework adapters"]}
>
  <PageHero
    breadcrumb={[{ label: "Frameworks" }]}
    title="Django. Flask. FastAPI."
    subtitle="Framework adapters handle discovery + lifecycle integration so you don't have to hand-wire anything. Pick your stack."
  />

  <Section>
    <div class="grid gap-6 md:grid-cols-3">
      {FRAMEWORKS.map((f) => (
        <Card
          href={`/frameworks/${f.slug}`}
          title={f.shortName}
          icon={f.icon}
          logo={f.logo}
          description={f.tagline}
        >
          <pre class="mt-2 overflow-x-auto rounded bg-[var(--color-code-bg)] p-3 text-xs font-mono text-slate-300">{f.installCmd}</pre>
        </Card>
      ))}
    </div>
  </Section>

  <CTA
    title="Your framework isn't here?"
    subtitle="z4j-bare works with any Python project, no framework adapter required. Direct agent install."
    primaryHref="https://z4j.dev/frameworks/bare/"
    primaryLabel="Use z4j-bare"
    secondaryHref="https://github.com/z4jdev"
    secondaryLabel="Request an adapter"
  />
</BaseLayout>
