---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/Section.astro";
import Card from "../../components/Card.astro";
import Icon from "../../components/Icon.astro";
import CTA from "../../components/CTA.astro";
import PackageHero from "../../components/PackageHero.astro";
import { SCHEDULERS } from "../../data/schedulers";
import { getEngine } from "../../data/engines";
import { getPackage } from "../../data/packages";

export function getStaticPaths() {
  return SCHEDULERS.map((s) => ({
    params: { slug: s.slug },
    props: { scheduler: s },
  }));
}
const { scheduler } = Astro.props;
const pkg = getPackage(scheduler.name);
const engine = getEngine(scheduler.engineSlug);
const other = SCHEDULERS.filter((s) => s.slug !== scheduler.slug).slice(0, 3);

const productSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: `z4j ${scheduler.shortName} adapter`,
  applicationCategory: "DeveloperApplication",
  operatingSystem: "Linux, macOS, Windows",
  description: scheduler.description,
  softwareVersion: pkg.latest,
  url: pkg.landing ?? `https://z4j.com/schedulers/${scheduler.slug}`,
  downloadUrl: pkg.pypi,
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  author: { "@type": "Organization", name: "z4j", url: "https://z4j.com" },
  featureList: scheduler.capabilities,
};

const metaTitle = `${scheduler.shortName} scheduler | z4j`;
const metaDescription = `${scheduler.tagline} ${scheduler.description.slice(0, 140)}`.slice(0, 160);
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  keywords={[scheduler.shortName, `${scheduler.shortName} scheduler`, "periodic tasks", "cron"]}
  jsonLd={productSchema}
  breadcrumbs={[
    { name: "Schedulers", href: "/schedulers" },
    { name: scheduler.shortName, href: `/schedulers/${scheduler.slug}` },
  ]}
>
  <PackageHero
    packageName={scheduler.name}
    shortName={scheduler.shortName}
    icon={scheduler.icon}
    logo={scheduler.logo}
    tagline={scheduler.tagline}
    description={scheduler.description}
    breadcrumb={[
      { label: "Schedulers", href: "/schedulers" },
      { label: scheduler.shortName },
    ]}
  />

  <Section compact>
    <div class="grid gap-6 md:grid-cols-2">
      <div>
        <h2 class="mb-4 text-xs font-semibold uppercase tracking-wider text-[var(--color-muted)]">
          Capabilities
        </h2>
        <ul class="space-y-2.5">
          {scheduler.capabilities.map((c) => (
            <li class="flex items-center gap-2.5 text-sm">
              <Icon name="check" size={15} class="text-[var(--color-accent)] shrink-0" />
              <span>{c}</span>
            </li>
          ))}
        </ul>
      </div>
      {scheduler.limitations.length > 0 && (
        <div>
          <h2 class="mb-4 text-xs font-semibold uppercase tracking-wider text-[var(--color-muted)]">
            Limitations
          </h2>
          <ul class="space-y-2.5">
            {scheduler.limitations.map((l) => (
              <li class="flex items-start gap-2.5 text-sm text-[var(--color-muted)]">
                <Icon name="minus" size={15} class="mt-0.5 shrink-0" />
                <span>{l}</span>
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>
  </Section>

  {engine && (
    <Section eyebrow="Paired engine" title={`Runs tasks on ${engine.shortName}`}>
      <Card
        href={`/engines/${engine.slug}`}
        title={engine.shortName}
        icon={engine.icon}
        logo={engine.logo}
        description={engine.tagline}
      />
    </Section>
  )}

  <Section eyebrow="More schedulers" title="See also">
    <div class="grid gap-4 md:grid-cols-3">
      {other.map((s) => (
        <Card
          href={`/schedulers/${s.slug}`}
          title={s.shortName}
          icon={s.icon}
          logo={s.logo}
          description={s.tagline}
        />
      ))}
    </div>
  </Section>

  <CTA
    title="Wire it up"
    primaryHref="/install"
    primaryLabel="Install z4j"
    secondaryHref={pkg.docs ?? "https://z4j.dev"}
    secondaryLabel={`${scheduler.shortName} docs`}
  />
</BaseLayout>
