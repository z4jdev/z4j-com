---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/Section.astro";
import Card from "../../components/Card.astro";
import CodeCopy from "../../components/CodeCopy.astro";
import Icon from "../../components/Icon.astro";
import PageHero from "../../components/PageHero.astro";
import CTA from "../../components/CTA.astro";
import { DEPLOYMENTS } from "../../data/deployments";
import { PLATFORMS } from "../../data/platforms";
import { ENGINES } from "../../data/engines";

const badgeClass: Record<string, string> = {
  accent: "bg-[var(--color-accent)]/15 text-[var(--color-accent)]",
  primary: "bg-[var(--color-primary)]/15 text-[var(--color-primary)]",
  warning: "bg-[var(--color-warning)]/20 text-[var(--color-warning)]",
};

const comparisonRows = [
  { label: "Container runtime required", values: ["None (pure Python)", "Docker", "Docker + Postgres"] },
  { label: "Database", values: ["SQLite", "SQLite (persisted volume)", "PostgreSQL 17+"] },
  { label: "Services to run", values: ["1 process", "1 container", "2 containers"] },
  { label: "Agent count", values: ["~10", "~50", "1000+"] },
  { label: "Events per minute", values: ["~1k", "~5k", "300k+"] },
  { label: "Horizontal scaling", values: [false, false, true] },
  { label: "Full-text search", values: [false, false, true] },
  { label: "Range-partitioned events", values: [false, false, true] },
  { label: "Auto-migrations", values: [true, true, true] },
  { label: "Auto-generated secrets", values: [true, true, false] },
  { label: "Compliance-friendly (Postgres)", values: [false, false, true] },
];

const tlsPatterns = [
  { id: "caddy", icon: "server", title: "Caddy overlay", desc: "One extra compose file. Auto-HTTPS via Let's Encrypt. Two minutes.", tag: "Homelab default" },
  { id: "traefik", icon: "globe", title: "Traefik labels", desc: "Already running Traefik? Add seven labels to the brain service." },
  { id: "cloudflare", icon: "shield", title: "Cloudflare Tunnel", desc: "Zero public ports. TLS terminates at Cloudflare's edge." },
  { id: "nginx", icon: "terminal", title: "nginx + certbot", desc: "Classic, familiar, works everywhere. On-host or in-container." },
];
---

<BaseLayout
  title="Install z4j | pip, default compose, or Postgres stack"
  description="Three ways to run z4j. Pure pip for homelabs, one-container Docker with SQLite for small teams, full Postgres stack for production. Pick your path, all under one roof."
  keywords={["install z4j", "Docker task queue dashboard", "pip install z4j", "homelab task queue", "production Celery dashboard"]}
>
  <PageHero
    breadcrumb={[{ label: "Install" }]}
    title="Install z4j."
    subtitle="Three deployment paths, one platform. Whether you run a homelab Raspberry Pi or a production Kubernetes cluster, the z4j feature set ships in every tier."
  />

  <Section>
    <div class="grid gap-5 lg:grid-cols-3">
      {
        DEPLOYMENTS.map((d) => (
          <article class="group relative flex flex-col rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 transition-all hover:border-[var(--color-primary)]/40 hover:shadow-lg hover:shadow-[var(--color-primary)]/5">
            <div class="mb-4 flex items-center justify-between">
              <div class="inline-flex size-11 items-center justify-center rounded-lg bg-[var(--color-primary)]/10 text-[var(--color-primary)]">
                <Icon name={d.icon} size={22} />
              </div>
              <span class={`rounded-full px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-wider ${badgeClass[d.badgeColor]}`}>
                {d.badge}
              </span>
            </div>
            <h2 class="text-xl font-bold tracking-tight">{d.name}</h2>
            <p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">{d.tagline}</p>
            <p class="mt-4 text-xs font-semibold uppercase tracking-wider text-[var(--color-muted)]">Best for</p>
            <p class="mt-1 text-sm">{d.audience}</p>
            <div class="mt-4 flex flex-wrap gap-1.5">
              {d.targetTiers.map((t) => (
                <span class="rounded-full bg-[var(--color-surface-raised)] px-2.5 py-0.5 text-[11px] font-medium text-[var(--color-muted)]">
                  {t}
                </span>
              ))}
            </div>
            <div class="mt-auto flex gap-2 pt-6">
              <a
                href={`#${d.slug}`}
                class="inline-flex items-center gap-1.5 rounded-lg bg-[var(--color-primary)] px-4 py-2 text-sm font-semibold text-white hover:opacity-90 transition-opacity"
              >
                Install
                <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M1 5h8m0 0L5 1m4 4L5 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
              <a
                href={`/install/${d.slug}`}
                class="inline-flex items-center rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-raised)] px-4 py-2 text-sm font-medium hover:border-[var(--color-primary)]/50 transition-colors"
              >
                Details
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </Section>

  <Section eyebrow="Side by side" title="Compare the three paths">
    <div class="overflow-hidden rounded-xl border border-[var(--color-border)]">
      <table class="w-full text-sm">
        <thead class="bg-[var(--color-surface)]">
          <tr class="text-left">
            <th class="px-4 py-3 font-semibold">Capability</th>
            {DEPLOYMENTS.map((d) => (
              <th class="px-4 py-3 font-semibold">{d.name}</th>
            ))}
          </tr>
        </thead>
        <tbody>
          {
            comparisonRows.map((row) => (
              <tr class="border-t border-[var(--color-border)] transition-colors hover:bg-[var(--color-surface)]/60">
                <td class="px-4 py-3 font-medium">{row.label}</td>
                {row.values.map((v) => (
                  <td class="px-4 py-3">
                    {typeof v === "boolean" ? (
                      v ? (
                        <Icon name="check" size={16} class="text-[var(--color-accent)]" />
                      ) : (
                        <Icon name="x" size={16} class="text-[var(--color-muted)]/50" />
                      )
                    ) : (
                      <span class="text-[var(--color-muted)]">{v}</span>
                    )}
                  </td>
                ))}
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </Section>

  {
    DEPLOYMENTS.map((d) => (
      <Section id={d.slug} eyebrow={d.badge} title={d.name} subtitle={d.tagline}>
        <div class="grid gap-8 lg:grid-cols-[1.2fr_1fr]">
          <div class="space-y-6">
            <div>
              <h3 class="mb-3 text-xs font-semibold uppercase tracking-wider text-[var(--color-muted)]">
                Install command
              </h3>
              <CodeCopy code={d.install} lang={d.installLang} />
            </div>

            <div>
              <h3 class="mb-3 text-xs font-semibold uppercase tracking-wider text-[var(--color-muted)]">
                What runs
              </h3>
              <div class="space-y-3">
                {d.containers.map((c, i) => (
                  <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-4">
                    <div class="flex items-center justify-between gap-3">
                      <div class="flex items-center gap-2.5">
                        <span class="inline-flex size-6 items-center justify-center rounded bg-[var(--color-primary)]/10 text-[var(--color-primary)] text-xs font-bold">
                          {i + 1}
                        </span>
                        <h4 class="text-sm font-semibold">{c.name}</h4>
                      </div>
                      {c.image && (
                        <code class="truncate rounded bg-[var(--color-surface-raised)] px-2 py-0.5 font-mono text-[10px] text-[var(--color-muted)]">
                          {c.image}
                        </code>
                      )}
                    </div>
                    <p class="mt-2 text-xs leading-relaxed text-[var(--color-muted)]">{c.purpose}</p>
                  </div>
                ))}
              </div>
            </div>

            <div>
              <h3 class="mb-3 text-xs font-semibold uppercase tracking-wider text-[var(--color-muted)]">
                Requirements
              </h3>
              <ul class="space-y-2">
                {d.requirements.map((r) => (
                  <li class="flex items-start gap-2.5 text-sm text-[var(--color-muted)]">
                    <Icon name="check" size={15} class="mt-0.5 text-[var(--color-accent)] shrink-0" />
                    <span>{r}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <div class="space-y-6">
            <div class="rounded-xl border border-[var(--color-accent)]/30 bg-[var(--color-accent)]/5 p-5">
              <div class="flex items-center gap-2 text-xs font-semibold uppercase tracking-wider text-[var(--color-accent)]">
                <Icon name="check" size={14} />
                Use this when
              </div>
              <ul class="mt-3 space-y-2">
                {d.whenToUse.map((u) => (
                  <li class="flex items-start gap-2.5 text-sm">
                    <Icon name="check" size={14} class="mt-0.5 text-[var(--color-accent)] shrink-0" />
                    <span>{u}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 space-y-3">
              <div>
                <div class="text-xs font-semibold uppercase tracking-wider text-[var(--color-muted)]">Database</div>
                <div class="mt-1 text-sm">{d.database}</div>
              </div>
              <div>
                <div class="text-xs font-semibold uppercase tracking-wider text-[var(--color-muted)]">Scale envelope</div>
                <div class="mt-1 text-sm">{d.scaleLimit}</div>
              </div>
            </div>

            <div class="flex gap-2">
              <a
                href={`/install/${d.slug}`}
                class="inline-flex items-center gap-1.5 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-2 text-sm font-semibold hover:border-[var(--color-primary)]/50 transition-colors"
              >
                Full details
                <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M1 5h8m0 0L5 1m4 4L5 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            </div>
          </div>
        </div>
      </Section>
    ))
  }

  <Section
    eyebrow="HTTPS setup"
    title="Reverse proxy, your choice."
    subtitle="z4j does not bundle a reverse proxy. Pick the TLS pattern that matches your existing infra."
  >
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
      {tlsPatterns.map((p) => (
        <a href={`/install/tls#${p.id}`} class="group flex flex-col rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 transition-all hover:-translate-y-0.5 hover:border-[var(--color-primary)]/40">
          <div class="mb-3 inline-flex size-9 items-center justify-center rounded-lg bg-[var(--color-primary)]/10 text-[var(--color-primary)]">
            <Icon name={p.icon} size={18} />
          </div>
          <h3 class="text-base font-semibold">{p.title}</h3>
          <p class="mt-1 text-xs text-[var(--color-muted)]">{p.desc}</p>
          {p.tag && (
            <span class="mt-3 inline-block rounded bg-[var(--color-accent)]/15 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-[var(--color-accent)] w-fit">
              {p.tag}
            </span>
          )}
        </a>
      ))}
    </div>
    <div class="mt-6">
      <a href="/install/tls" class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--color-primary)] hover:underline">
        Full TLS setup guide
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M1 5h8m0 0L5 1m4 4L5 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </Section>

  <Section
    eyebrow="Next step"
    title="Install the agent in your app"
    subtitle="After the brain is running, drop the agent package into your Django, Flask, or FastAPI app. One pip install plus three environment variables."
  >
    <div class="grid gap-4 md:grid-cols-3">
      {
        PLATFORMS.map((p) => (
          <Card
            href={`/platforms/${p.slug}`}
            title={p.shortName}
            icon={p.icon}
            logo={p.logo}
            description={p.tagline}
          >
            <pre class="mt-2 overflow-x-auto rounded bg-[var(--color-code-bg)] p-2 font-mono text-[11px] text-slate-300">{p.installCmd}</pre>
          </Card>
        ))
      }
    </div>
  </Section>

  <Section
    eyebrow="Pick your engine"
    title="Every tier supports every engine"
    subtitle="Install one or more engine adapters alongside your framework. Every deployment tier supports all six."
  >
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {
        ENGINES.map((e) => (
          <Card
            href={`/engines/${e.slug}`}
            title={e.shortName}
            icon={e.icon}
            logo={e.logo}
            description={e.tagline}
          />
        ))
      }
    </div>
  </Section>

  <Section
    eyebrow="Architecture FAQ"
    title="One image, one clear story."
    subtitle="Answers to the common confusions about z4j's container layout."
  >
    <div class="grid gap-4 md:grid-cols-2">
      <article class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6">
        <h3 class="text-base font-semibold">Is the frontend a separate container?</h3>
        <p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
          No. The brain image bundles the FastAPI backend and the compiled React dashboard together. The backend serves the dashboard as static HTML, CSS, and JS from the same process. There is no second container for the UI.
        </p>
      </article>

      <article class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6">
        <h3 class="text-base font-semibold">Is there a separate image for each tier?</h3>
        <p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
          No. Both Docker tiers use the same <code class="rounded bg-[var(--color-surface-raised)] px-1.5 py-0.5 font-mono text-xs">z4jdev/z4j</code> image. The runtime picks SQLite or Postgres based on the <code class="rounded bg-[var(--color-surface-raised)] px-1.5 py-0.5 font-mono text-xs">Z4J_DATABASE_URL</code> environment variable.
        </p>
      </article>

      <article class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6">
        <h3 class="text-base font-semibold">Then what are the image tags for?</h3>
        <p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
          Tags pin <strong>versions</strong>, not modes. Use <code class="rounded bg-[var(--color-surface-raised)] px-1.5 py-0.5 font-mono text-xs">:latest</code> for the most recent release, <code class="rounded bg-[var(--color-surface-raised)] px-1.5 py-0.5 font-mono text-xs">:1.0.0</code> to pin a specific version, and <code class="rounded bg-[var(--color-surface-raised)] px-1.5 py-0.5 font-mono text-xs">:edge</code> for pre-releases.
        </p>
      </article>

      <article class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6">
        <h3 class="text-base font-semibold">How many services for z4j + Postgres?</h3>
        <p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
          Two. <code class="rounded bg-[var(--color-surface-raised)] px-1.5 py-0.5 font-mono text-xs">z4j-brain</code> runs the backend and dashboard from one image. <code class="rounded bg-[var(--color-surface-raised)] px-1.5 py-0.5 font-mono text-xs">z4j-postgres</code> runs Postgres. No separate frontend.
        </p>
      </article>

      <article class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6">
        <h3 class="text-base font-semibold">Does the brain need Redis or RabbitMQ?</h3>
        <p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
          No. The brain communicates with your agents over a direct WebSocket. Your task queue engine uses whatever broker it already uses (Redis, RabbitMQ, SQS). The brain observes, it does not re-broker.
        </p>
      </article>

      <article class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6">
        <h3 class="text-base font-semibold">Can I migrate from SQLite to Postgres later?</h3>
        <p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
          Yes. Point <code class="rounded bg-[var(--color-surface-raised)] px-1.5 py-0.5 font-mono text-xs">Z4J_DATABASE_URL</code> at your Postgres instance and restart. The same image reconnects, runs migrations, and picks up your users, audit chain, and schedules.
        </p>
      </article>
    </div>
  </Section>

  <CTA
    title="Still picking a tier?"
    subtitle="Solo developer or homelab: start with pip. Team of 2-20: default z4j compose. Anyone with existing Postgres or compliance needs: z4j + Postgres."
    primaryHref="#z4j"
    primaryLabel="Start with z4j (default)"
    secondaryHref="https://z4j.dev/getting-started/install/"
    secondaryLabel="Full install docs"
  />
</BaseLayout>
