---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/Section.astro";
import Card from "../../components/Card.astro";
import Icon from "../../components/Icon.astro";
import PageHero from "../../components/PageHero.astro";
import CTA from "../../components/CTA.astro";
import { FEATURES } from "../../data/features";

const packages = [
  {
    name: "z4j-core",
    tagline: "Framework-free, engine-free domain core",
    license: "Apache 2.0",
    lives: "Inside every agent and the brain",
    purpose: "Protocol definitions, domain models, redaction engine, HMAC envelope, serialization. Knows nothing about Django, Celery, or Redis.",
  },
  {
    name: "z4j-bare",
    tagline: "Framework-free agent bootstrapper",
    license: "Apache 2.0",
    lives: "Inside your app process",
    purpose: "Connects to the brain, buffers events to local SQLite, manages lifecycle. Use directly when you have no web framework.",
  },
  {
    name: "z4j-<framework>",
    tagline: "Framework adapter (django, flask, fastapi)",
    license: "Apache 2.0",
    lives: "Inside your app process",
    purpose: "Reads your framework's settings, auto-registers adapters on app startup, hooks into the framework's lifecycle.",
  },
  {
    name: "z4j-<engine>",
    tagline: "Engine adapter (celery, rq, dramatiq, huey, arq, taskiq)",
    license: "Apache 2.0",
    lives: "Inside your app process",
    purpose: "Captures task events from the engine's signals, middleware, or hooks. Executes commands (retry, cancel, purge) against the engine.",
  },
  {
    name: "z4j-<scheduler>",
    tagline: "Scheduler adapter (celery-beat, apscheduler, ...)",
    license: "Apache 2.0",
    lives: "Inside your app process",
    purpose: "Surfaces periodic tasks on the Schedules page. Handles schedule CRUD where the scheduler supports runtime mutation.",
  },
  {
    name: "z4j-brain",
    tagline: "FastAPI backend + React dashboard",
    license: "AGPL v3",
    lives: "Standalone container or pip install",
    purpose: "Stores events in Postgres or SQLite, serves the dashboard, authenticates users, dispatches commands back to agents. One image, many agents.",
  },
];

const pillars = [
  {
    id: "observability",
    icon: "unified-actions",
    label: "Observability",
    desc: "Tasks, workers, queues, schedules. Real-time + historical.",
    slugs: ["trends", "visual-dag", "redis-streams"],
  },
  {
    id: "actions",
    icon: "reconciliation",
    label: "Actions",
    desc: "Retry, cancel, bulk-retry, purge, requeue DLQ. Dynamic scheduler.",
    slugs: ["unified-actions", "reconciliation", "worker-restart", "dynamic-scheduler"],
  },
  {
    id: "security",
    icon: "shield",
    label: "Security",
    desc: "RBAC, audit log, redaction, HMAC wire protocol.",
    slugs: ["rbac", "redaction", "audit-log", "rate-limiting"],
  },
  {
    id: "collaboration",
    icon: "invitations",
    label: "Collaboration",
    desc: "Multi-user projects, invitations, password reset.",
    slugs: ["invitations", "password-reset"],
  },
  {
    id: "alerts",
    icon: "notifications",
    label: "Alerts",
    desc: "Six providers, severity-aware subscriptions, per-channel cooldown.",
    slugs: [
      "notification-providers",
      "notification-levels",
      "notification-cooldown",
    ],
  },
  {
    id: "run-anywhere",
    icon: "run-anywhere",
    label: "Run anywhere",
    desc: "Pip + SQLite. Docker AMD64. Docker ARM64. Native, not emulated.",
    slugs: ["install-pip", "install-amd64", "install-arm64"],
  },
];

function featuresFor(slugs: string[]) {
  return slugs
    .map((s) => FEATURES.find((f) => f.slug === s))
    .filter((f): f is typeof FEATURES[number] => Boolean(f));
}
---

<BaseLayout
  title="Features + architecture | z4j"
  description="Every z4j capability in one place: unified actions, reconciliation, trends, visual DAG, RBAC, invitations, redaction, HMAC audit log, rate limits, worker restart, real-time dashboard. Plus the architecture that makes it work."
  keywords={["z4j features", "task queue features", "Celery dashboard features", "z4j architecture"]}
>
  <PageHero
    breadcrumb={[{ label: "Features" }]}
    title="Everything z4j ships, in one place."
    subtitle="Every capability below lands on day one. No hidden tiers. No enterprise-only gating. Security, observability, actions, and team collaboration, all in the open-source release."
  >
    <nav aria-label="Jump to section" class="mt-6 flex flex-wrap gap-2">
      {pillars.map((p) => (
        <a
          href={`#${p.id}`}
          class="inline-flex items-center gap-1.5 rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-1 text-xs font-medium text-[var(--color-muted)] transition-colors hover:border-[var(--color-primary)]/40 hover:text-[var(--color-fg)]"
        >
          <Icon name={p.icon} size={12} />
          {p.label}
          <span class="text-[var(--color-muted)]/70">{p.slugs.length}</span>
        </a>
      ))}
      <a
        href="#architecture"
        class="inline-flex items-center gap-1.5 rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-1 text-xs font-medium text-[var(--color-muted)] transition-colors hover:border-[var(--color-primary)]/40 hover:text-[var(--color-fg)]"
      >
        Architecture
      </a>
    </nav>
  </PageHero>

  <!-- Six pillars in a 3-up grid -->
  <Section compact>
    <div class="grid gap-px overflow-hidden rounded-lg border border-[var(--color-border)] bg-[var(--color-border)] sm:grid-cols-2 lg:grid-cols-3">
      {pillars.map((p) => (
        <a
          href={`#${p.id}`}
          class="group relative flex flex-col overflow-hidden bg-[var(--color-surface)] p-5 transition-colors hover:bg-[var(--color-surface-raised)]"
        >
          <span
            aria-hidden="true"
            class="pointer-events-none absolute inset-y-0 left-0 w-0.5 origin-top scale-y-0 bg-[var(--color-primary)] transition-transform duration-300 group-hover:scale-y-100"
          ></span>
          <div class="flex items-center gap-3">
            <span class="inline-flex size-10 items-center justify-center rounded-md border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-muted)] transition-all duration-300 group-hover:-translate-y-0.5 group-hover:border-[var(--color-primary)]/40 group-hover:bg-[var(--color-primary)]/10 group-hover:text-[var(--color-primary)]">
              <Icon name={p.icon} size={18} />
            </span>
            <div class="min-w-0 flex-1">
              <h2 class="text-sm font-semibold tracking-tight">{p.label}</h2>
              <div class="font-mono text-[11px] font-medium uppercase tracking-wider text-[var(--color-muted)]">
                <span class="text-[var(--color-primary)]">{String(p.slugs.length).padStart(2, "0")}</span> {p.slugs.length === 1 ? "capability" : "capabilities"}
              </div>
            </div>
            <svg
              aria-hidden="true"
              class="size-3 shrink-0 -translate-x-1 text-[var(--color-primary)] opacity-0 transition-all duration-300 group-hover:translate-x-0 group-hover:opacity-100"
              viewBox="0 0 10 10"
              fill="none"
            >
              <path d="M1 5h8m0 0L5 1m4 4L5 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
          <p class="mt-3 text-sm leading-relaxed text-[var(--color-muted)]">{p.desc}</p>
        </a>
      ))}
    </div>
  </Section>

  <!-- Grouped feature catalog -->
  <Section eyebrow="All capabilities" title="Feature catalog" subtitle="Click any card for a deeper look with screenshots and config notes." compact />

  {pillars.map((p, i) => (
    <section
      id={p.id}
      class:list={[
        "scroll-mt-24 border-t border-[var(--color-border)]",
        i % 2 === 1 && "bg-[var(--color-surface)]/40",
      ]}
    >
      <div class="mx-auto w-full max-w-6xl px-4 py-16 md:px-6 md:py-20">
        <header class="mb-10 flex flex-wrap items-center gap-4">
          <span class="inline-flex size-12 items-center justify-center rounded-lg border border-[var(--color-primary)]/30 bg-[var(--color-primary)]/10 text-[var(--color-primary)]">
            <Icon name={p.icon} size={22} />
          </span>
          <div class="min-w-0 flex-1">
            <div class="font-mono text-[10px] font-semibold uppercase tracking-wider text-[var(--color-muted)]">
              Pillar {String(i + 1).padStart(2, "0")} of {String(pillars.length).padStart(2, "0")}
            </div>
            <h3 class="mt-1 text-2xl font-semibold tracking-tight md:text-3xl">{p.label}</h3>
            <p class="mt-1 text-sm leading-relaxed text-[var(--color-muted)] md:text-base">{p.desc}</p>
          </div>
          <span class="rounded-full border border-[var(--color-border)] bg-[var(--color-bg)] px-3 py-1 font-mono text-[11px] font-semibold uppercase tracking-wider text-[var(--color-primary)]">
            {String(p.slugs.length).padStart(2, "0")} {p.slugs.length === 1 ? "capability" : "capabilities"}
          </span>
        </header>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {featuresFor(p.slugs).map((f) => (
            <Card
              href={`/features/${f.slug}`}
              title={f.title}
              icon={f.icon}
              description={f.tagline}
            />
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- Architecture (responsive HTML diagram) -->
  <Section
    id="architecture"
    eyebrow="How it works"
    title="The control-plane architecture"
    subtitle="z4j separates the brain (central server + dashboard) from agents (thin pip packages that run in your app). Agents push events over an outbound WebSocket. The brain dispatches commands back over the same channel."
  >
    <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 md:p-8">
      <div class="grid gap-5 lg:grid-cols-[1fr_auto_1fr] lg:items-stretch lg:gap-6">
        <!-- Left: your application -->
        <div class="flex flex-col rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)]/50 p-4 md:p-5">
          <div class="mb-4 flex items-center justify-between gap-2">
            <span class="text-[11px] font-semibold uppercase tracking-wider text-[var(--color-muted)]">
              Your application
            </span>
            <span class="rounded-full bg-[var(--color-accent)]/15 px-2 py-0.5 text-[10px] font-semibold text-[var(--color-accent)]">
              Apache 2.0
            </span>
          </div>
          <div class="space-y-3">
            <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] p-3">
              <div class="text-sm font-semibold">Django / Flask / FastAPI</div>
              <div class="mt-1 font-mono text-[11px] text-[var(--color-muted)]">
                z4j-django · z4j-flask · z4j-fastapi
              </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] p-3">
                <div class="text-sm font-semibold">Engine</div>
                <div class="mt-1 font-mono text-[10px] text-[var(--color-muted)]">z4j-celery, ...</div>
              </div>
              <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] p-3">
                <div class="text-sm font-semibold">Scheduler</div>
                <div class="mt-1 font-mono text-[10px] text-[var(--color-muted)]">z4j-celerybeat, ...</div>
              </div>
            </div>
            <div class="rounded-lg border border-[var(--color-primary)]/40 bg-[var(--color-primary)]/10 p-3">
              <div class="text-sm font-bold text-[var(--color-primary)]">z4j-bare (agent runtime)</div>
              <div class="mt-1 font-mono text-[10px] text-[var(--color-muted)]">
                WebSocket + local SQLite buffer
              </div>
            </div>
            <div class="rounded-lg border border-dashed border-[var(--color-border)] bg-[var(--color-bg)] p-3">
              <div class="text-sm font-semibold">z4j-core</div>
              <div class="mt-1 font-mono text-[10px] text-[var(--color-muted)]">
                Protocols + domain models + redaction
              </div>
            </div>
            <div class="rounded-lg bg-[var(--color-surface-raised)] p-3 text-center">
              <div class="text-[11px] font-medium text-[var(--color-muted)]">
                Celery / RQ / Dramatiq / Huey / arq / taskiq run alongside, unchanged
              </div>
              <div class="mt-1 text-[10px] text-[var(--color-muted)]/80">
                broker: Redis / RabbitMQ / SQS (their own)
              </div>
            </div>
          </div>
        </div>

        <!-- Middle: link -->
        <div class="flex flex-col items-center justify-center gap-3 px-2 py-2 lg:py-0">
          <div class="hidden lg:block lg:h-8" />
          <div class="flex w-full items-center gap-3 lg:w-auto lg:flex-col">
            <!-- Top arrow (events →) -->
            <div class="flex flex-1 flex-col items-center gap-1 lg:flex-none">
              <span class="text-[11px] font-semibold text-[var(--color-primary)]">
                events <span class="hidden lg:inline">→</span><span class="lg:hidden">↓</span>
              </span>
              <div class="h-px w-full bg-[var(--color-primary)]/50 lg:h-16 lg:w-px" />
            </div>
            <!-- Bottom arrow (← commands) -->
            <div class="flex flex-1 flex-col items-center gap-1 lg:flex-none">
              <div class="h-px w-full bg-[var(--color-primary)]/50 lg:h-16 lg:w-px" />
              <span class="text-[11px] font-semibold text-[var(--color-primary)]">
                <span class="hidden lg:inline">←</span><span class="lg:hidden">↑</span> commands
              </span>
            </div>
          </div>
          <div class="rounded-full bg-[var(--color-surface-raised)] px-2.5 py-1 font-mono text-[10px] text-[var(--color-muted)]">
            HMAC-signed WebSocket
          </div>
        </div>

        <!-- Right: brain + DB -->
        <div class="flex flex-col gap-3">
          <div class="flex flex-col rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)]/50 p-4 md:p-5">
            <div class="mb-4 flex items-center justify-between gap-2">
              <span class="text-[11px] font-semibold uppercase tracking-wider text-[var(--color-muted)]">
                z4j-brain (control plane)
              </span>
              <span class="rounded-full bg-[var(--color-warning)]/20 px-2 py-0.5 text-[10px] font-semibold text-[var(--color-warning)]">
                AGPL 3.0
              </span>
            </div>
            <div class="space-y-3">
              <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] p-3">
                <div class="text-sm font-semibold">FastAPI backend</div>
                <div class="mt-1 font-mono text-[11px] text-[var(--color-muted)]">
                  REST API + WebSocket gateway
                </div>
              </div>
              <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] p-3">
                <div class="text-sm font-semibold">React dashboard</div>
                <div class="mt-1 font-mono text-[11px] text-[var(--color-muted)]">
                  TanStack Start v1, bundled in image
                </div>
              </div>
              <div class="rounded-lg border border-dashed border-[var(--color-border)] bg-[var(--color-bg)] p-3">
                <div class="text-sm font-semibold">Background workers</div>
                <div class="mt-1 font-mono text-[11px] text-[var(--color-muted)]">
                  Reconciliation, retention, health
                </div>
              </div>
            </div>
          </div>
          <div class="rounded-xl border border-[oklch(0.75_0.16_80/0.3)] bg-[oklch(0.75_0.16_80/0.08)] p-4">
            <div class="text-sm font-semibold text-[oklch(0.7_0.2_80)]">
              PostgreSQL 18+ (or SQLite in default mode)
            </div>
            <div class="mt-1 font-mono text-[11px] text-[var(--color-muted)]">
              Events, tasks, schedules, audit log, users
            </div>
            <div class="mt-1 text-[10px] text-[var(--color-muted)]/80">
              HMAC-chained, tamper-evident
            </div>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- Package map -->
  <Section
    eyebrow="Package map"
    title="What ships, where it lives, under which license"
    subtitle="z4j is a monorepo. Each piece is installable as an independent pip package. Agents are Apache 2.0, the brain is AGPL 3.0, everything else is documented below."
  >
    <!-- Desktop table -->
    <div class="hidden overflow-hidden rounded-xl border border-[var(--color-border)] md:block">
      <table class="w-full text-sm">
        <thead class="bg-[var(--color-surface)]">
          <tr class="text-left">
            <th class="px-4 py-3 font-semibold">Package</th>
            <th class="px-4 py-3 font-semibold">Role</th>
            <th class="px-4 py-3 font-semibold">Runs in</th>
            <th class="px-4 py-3 font-semibold">License</th>
          </tr>
        </thead>
        <tbody>
          {
            packages.map((p) => (
              <tr class="border-t border-[var(--color-border)] transition-colors hover:bg-[var(--color-surface)]/60">
                <td class="px-4 py-3 font-mono text-xs whitespace-nowrap text-[var(--color-primary)]">{p.name}</td>
                <td class="px-4 py-3">
                  <div class="font-medium">{p.tagline}</div>
                  <div class="mt-1 text-xs text-[var(--color-muted)]">{p.purpose}</div>
                </td>
                <td class="px-4 py-3 text-sm text-[var(--color-muted)] whitespace-nowrap">{p.lives}</td>
                <td class="px-4 py-3">
                  <span class={`rounded-full px-2 py-0.5 text-[10px] font-semibold ${p.license === "Apache 2.0" ? "bg-[var(--color-accent)]/15 text-[var(--color-accent)]" : "bg-[var(--color-warning)]/20 text-[var(--color-warning)]"}`}>
                    {p.license}
                  </span>
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
    <!-- Mobile cards -->
    <div class="grid gap-3 md:hidden">
      {
        packages.map((p) => (
          <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-4">
            <div class="flex items-start justify-between gap-2">
              <code class="font-mono text-xs text-[var(--color-primary)]">{p.name}</code>
              <span class={`shrink-0 rounded-full px-2 py-0.5 text-[10px] font-semibold ${p.license === "Apache 2.0" ? "bg-[var(--color-accent)]/15 text-[var(--color-accent)]" : "bg-[var(--color-warning)]/20 text-[var(--color-warning)]"}`}>
                {p.license}
              </span>
            </div>
            <div class="mt-2 text-sm font-medium">{p.tagline}</div>
            <p class="mt-1.5 text-xs leading-relaxed text-[var(--color-muted)]">{p.purpose}</p>
            <div class="mt-3 border-t border-[var(--color-border)] pt-2 text-[11px] text-[var(--color-muted)]">
              <span class="font-semibold text-[var(--color-muted)]/80">Runs in:</span> {p.lives}
            </div>
          </div>
        ))
      }
    </div>
  </Section>

  <!-- Data flow -->
  <Section eyebrow="Data flow" title="How an event travels from your app to the dashboard">
    <ol class="grid gap-5 md:grid-cols-2">
      {[
        {
          title: "Your task runs",
          body: "Celery or RQ or any engine dispatches a task. The engine adapter (z4j-celery, z4j-rq, ...) hooks into the engine's signal, middleware, or job lifecycle.",
        },
        {
          title: "Redaction at capture",
          body: "Before the event leaves your process, the z4j-core redaction engine scrubs args, kwargs, return values, and exceptions. API keys, tokens, and PII never cross the wire unredacted.",
        },
        {
          title: "Buffered to local SQLite",
          body: "The agent (z4j-bare) appends the event to a local SQLite buffer. If the brain is unreachable, events queue here safely and flush on reconnect. Your app keeps running regardless.",
        },
        {
          title: "HMAC-signed over WebSocket",
          body: "The agent batches events and sends them through a bearer-authenticated, HMAC-signed WebSocket. Replay guard (nonce + monotonic seq + timestamp window) prevents tampering.",
        },
        {
          title: "Brain persists + broadcasts",
          body: "The brain writes the event to Postgres or SQLite, applies a second-layer redaction pass, appends to the audit chain if it was a command, then broadcasts the state change to every connected dashboard via internal pub/sub.",
        },
        {
          title: "Dashboard updates in real time",
          body: "Browsers pick up the update over their own WebSocket. Typical end-to-end latency: agent event to UI under 200ms p50.",
        },
      ].map((step, i) => (
        <li class="flex gap-4 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5">
          <span class="inline-flex size-8 shrink-0 items-center justify-center rounded-full bg-[var(--color-primary)] text-sm font-bold text-white">
            {i + 1}
          </span>
          <div class="min-w-0">
            <h3 class="font-semibold">{step.title}</h3>
            <p class="mt-1 text-sm leading-relaxed text-[var(--color-muted)]">{step.body}</p>
          </div>
        </li>
      ))}
    </ol>
  </Section>

  <CTA
    title="Ready to try it?"
    subtitle="Install in under 5 minutes. The same features ship in every deployment tier."
    primaryHref="/install"
    primaryLabel="Install z4j"
    secondaryHref="/engines"
    secondaryLabel="See engine support"
  />
</BaseLayout>
