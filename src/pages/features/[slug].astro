---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/Section.astro";
import Card from "../../components/Card.astro";
import Icon from "../../components/Icon.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import FeatureScreenshot from "../../components/FeatureScreenshot.astro";
import CTA from "../../components/CTA.astro";
import { FEATURES } from "../../data/features";

export function getStaticPaths() {
  return FEATURES.map((f) => ({
    params: { slug: f.slug },
    props: { feature: f },
  }));
}

const { feature } = Astro.props;
const related = FEATURES.filter((f) => f.slug !== feature.slug).slice(0, 3);

const techArticleSchema = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  headline: feature.title,
  description: feature.summary,
  url: `https://z4j.com/features/${feature.slug}`,
  author: { "@type": "Organization", name: "z4j", url: "https://z4j.com" },
  publisher: {
    "@type": "Organization",
    name: "z4j",
    logo: { "@type": "ImageObject", url: "https://z4j.com/logos/z4j-mark.svg" },
  },
  mainEntityOfPage: `https://z4j.com/features/${feature.slug}`,
};

const metaTitle = `${feature.title} | z4j`;
const metaDescription = `${feature.tagline} ${feature.summary.slice(0, 140)}`.slice(0, 160);
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  ogType="article"
  keywords={[feature.title, feature.tagline]}
  jsonLd={techArticleSchema}
  breadcrumbs={[
    { name: "Features", href: "/features" },
    { name: feature.title, href: `/features/${feature.slug}` },
  ]}
>
  <Section compact>
    <Breadcrumb items={[
      { label: "Features", href: "/features" },
      { label: feature.title },
    ]} />
    <div class="max-w-3xl">
      <div class="mb-4 inline-flex size-14 items-center justify-center rounded-xl bg-[var(--color-primary)]/10 text-[var(--color-primary)]">
        <Icon name={feature.icon} size={28} />
      </div>
      <h1 class="text-4xl font-bold tracking-tight md:text-5xl">
        {feature.title}
      </h1>
      <p class="mt-4 text-xl font-medium text-[var(--color-primary)]">{feature.tagline}</p>
      <p class="mt-6 text-lg leading-relaxed text-[var(--color-muted)]">
        {feature.summary}
      </p>
    </div>
  </Section>

  <Section compact>
    <figcaption class="mb-3 text-xs font-semibold uppercase tracking-wider text-[var(--color-muted)]">
      Preview
    </figcaption>
    <FeatureScreenshot slug={feature.slug} title={feature.title} />
    <p class="mt-3 text-xs text-[var(--color-muted)]">
      Mockup of the dashboard view for this feature. Live-reloading and themed to match your dashboard.
    </p>
  </Section>

  <Section compact>
    <div class="grid gap-8 md:grid-cols-2">
      <div>
        <h2 class="mb-4 text-xs font-semibold uppercase tracking-wider text-[var(--color-muted)]">
          Ships with
        </h2>
        <ul class="space-y-3">
          {
            feature.bullets.map((b) => (
              <li class="flex items-start gap-3 text-sm">
                <Icon name="check" size={16} class="mt-0.5 text-[var(--color-accent)] shrink-0" />
                <span>{b}</span>
              </li>
            ))
          }
        </ul>
      </div>

      {
        feature.highlights && (
          <div>
            <h2 class="mb-4 text-xs font-semibold uppercase tracking-wider text-[var(--color-muted)]">
              Highlights
            </h2>
            <ul class="space-y-3">
              {feature.highlights.map((h) => (
                <li class="flex items-start gap-3 text-sm">
                  <Icon name="check" size={16} class="mt-0.5 text-[var(--color-primary)] shrink-0" />
                  <span>{h}</span>
                </li>
              ))}
            </ul>
          </div>
        )
      }
    </div>
  </Section>

  <Section eyebrow="Related" title="More capabilities">
    <div class="grid gap-4 md:grid-cols-3">
      {
        related.map((f) => (
          <Card
            href={`/features/${f.slug}`}
            title={f.title}
            icon={f.icon}
            description={f.tagline}
          />
        ))
      }
    </div>
  </Section>

  <CTA
    title="Ready to try z4j?"
    primaryHref="/install"
    primaryLabel="Install z4j"
    secondaryHref={`https://z4j.dev/features/${feature.slug}/`}
    secondaryLabel="Feature docs"
  />
</BaseLayout>
