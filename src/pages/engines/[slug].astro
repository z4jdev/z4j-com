---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/Section.astro";
import Card from "../../components/Card.astro";
import Icon from "../../components/Icon.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import CodeCopy from "../../components/CodeCopy.astro";
import CTA from "../../components/CTA.astro";
import { ENGINES } from "../../data/engines";
import { getScheduler } from "../../data/schedulers";

export function getStaticPaths() {
  return ENGINES.map((e) => ({
    params: { slug: e.slug },
    props: { engine: e },
  }));
}

const { engine } = Astro.props;
const paired = getScheduler(engine.schedulerSlug);
const other = ENGINES.filter((e) => e.slug !== engine.slug).slice(0, 3);

const productSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: `z4j for ${engine.shortName}`,
  applicationCategory: "DeveloperApplication",
  operatingSystem: "Linux, macOS, Windows",
  description: engine.description,
  url: `https://z4j.com/engines/${engine.slug}`,
  downloadUrl: `https://pypi.org/project/${engine.pypi}/`,
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
    availability: "https://schema.org/InStock",
  },
  author: { "@type": "Organization", name: "z4j", url: "https://z4j.com" },
  featureList: engine.nativeActions.concat(engine.brainPolyfilledActions),
};

const metaTitle = `${engine.shortName} adapter | z4j`;
const metaDescription = `${engine.tagline} ${engine.description.slice(0, 140)}`.slice(0, 160);
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  keywords={[engine.shortName, `${engine.shortName} dashboard`, `${engine.shortName} monitoring`, engine.pypi]}
  jsonLd={productSchema}
  breadcrumbs={[
    { name: "Engines", href: "/engines" },
    { name: engine.shortName, href: `/engines/${engine.slug}` },
  ]}
>
  <Section compact>
    <Breadcrumb items={[
      { label: "Engines", href: "/engines" },
      { label: engine.shortName },
    ]} />
    <div class="flex flex-wrap items-center gap-5">
      {engine.upstreamUrl ? (
        <a
          href={engine.upstreamUrl}
          rel="nofollow noopener"
          target="_blank"
          title={`${engine.shortName} upstream project`}
          class="inline-flex size-16 items-center justify-center rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] transition-colors hover:border-[var(--color-primary)]/40"
        >
          {engine.logo ? (
            <img src={engine.logo} alt={`${engine.shortName} logo`} class="size-10 object-contain" />
          ) : (
            <Icon name={engine.icon} size={32} class="text-[var(--color-primary)]" />
          )}
        </a>
      ) : engine.logo ? (
        <div class="inline-flex size-16 items-center justify-center rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)]">
          <img src={engine.logo} alt={`${engine.shortName} logo`} class="size-10 object-contain" />
        </div>
      ) : (
        <div class="inline-flex size-16 items-center justify-center rounded-xl bg-[var(--color-primary)]/10 text-[var(--color-primary)]">
          <Icon name={engine.icon} size={32} />
        </div>
      )}
      <div>
        <div class="flex items-center gap-3">
          <h1 class="text-4xl font-bold tracking-tight md:text-5xl">
            {engine.shortName}
          </h1>
          <span
            class={`rounded-full px-2.5 py-0.5 text-xs font-semibold ${engine.firstShipped === "v1.0 (new)" ? "bg-[var(--color-accent)]/15 text-[var(--color-accent)]" : "bg-[var(--color-primary)]/15 text-[var(--color-primary)]"}`}
          >
            {engine.firstShipped}
          </span>
        </div>
        <p class="mt-1 font-mono text-sm text-[var(--color-muted)]">
          {engine.name}
          {engine.upstreamUrl && (
            <>
              {" "}&middot;{" "}
              <a
                href={engine.upstreamUrl}
                rel="nofollow noopener"
                target="_blank"
                class="text-[var(--color-primary)] hover:underline"
              >
                Upstream project
              </a>
            </>
          )}
        </p>
      </div>
    </div>
    <p class="mt-6 max-w-3xl text-xl font-medium text-[var(--color-primary)]">{engine.tagline}</p>
    <p class="mt-4 max-w-3xl text-lg leading-relaxed text-[var(--color-muted)]">
      {engine.description}
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a
        href={engine.docsHref}
        class="inline-flex items-center gap-1.5 rounded-lg bg-[var(--color-primary)] px-5 py-2.5 text-sm font-semibold text-white hover:opacity-90 transition-opacity"
      >
        Engine docs
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M1 5h8m0 0L5 1m4 4L5 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <a
        href={`https://pypi.org/project/${engine.pypi}/`}
        class="inline-flex items-center rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] px-5 py-2.5 text-sm font-semibold hover:border-[var(--color-primary)]/50 transition-colors"
      >
        PyPI: {engine.pypi}
      </a>
    </div>
  </Section>

  <Section compact>
    <h2 class="mb-4 text-xs font-semibold uppercase tracking-wider text-[var(--color-muted)]">
      Install
    </h2>
    <CodeCopy code={`pip install ${engine.pypi}`} lang="bash" />
  </Section>

  <Section>
    <div class="grid gap-8 md:grid-cols-2">
      <div>
        <h2 class="mb-4 text-xs font-semibold uppercase tracking-wider text-[var(--color-muted)]">
          Native actions
        </h2>
        <ul class="space-y-2.5">
          {
            engine.nativeActions.map((a) => (
              <li class="flex items-center gap-2.5 text-sm">
                <Icon name="check" size={15} class="text-[var(--color-accent)] shrink-0" />
                <code class="rounded bg-[var(--color-surface-raised)] px-1.5 py-0.5 font-mono text-xs">{a}</code>
              </li>
            ))
          }
        </ul>
      </div>
      {
        engine.brainPolyfilledActions.length > 0 && (
          <div>
            <h2 class="mb-4 text-xs font-semibold uppercase tracking-wider text-[var(--color-muted)]">
              Brain-polyfilled actions
            </h2>
            <ul class="space-y-2.5">
              {engine.brainPolyfilledActions.map((a) => (
                <li class="flex items-center gap-2.5 text-sm">
                  <Icon name="reconciliation" size={15} class="text-[var(--color-primary)] shrink-0" />
                  <code class="rounded bg-[var(--color-surface-raised)] px-1.5 py-0.5 font-mono text-xs">{a}</code>
                </li>
              ))}
            </ul>
            <p class="mt-3 text-xs text-[var(--color-muted)]">
              The brain fetches the original args from its tasks table and
              lowers to submit_task transparently. The dashboard shows the
              same button regardless.
            </p>
          </div>
        )
      }
      {
        engine.nonSupported.length > 0 && (
          <div>
            <h2 class="mb-4 text-xs font-semibold uppercase tracking-wider text-[var(--color-muted)]">
              Not supported
            </h2>
            <ul class="space-y-2.5">
              {engine.nonSupported.map((a) => (
                <li class="flex items-start gap-2.5 text-sm">
                  <Icon name="x" size={15} class="mt-0.5 text-[var(--color-muted)] shrink-0" />
                  <span class="text-[var(--color-muted)]">{a}</span>
                </li>
              ))}
            </ul>
            <p class="mt-3 text-xs text-[var(--color-muted)]">
              Engine-level limitations, not a roadmap gap. These actions
              require primitives the engine does not expose.
            </p>
          </div>
        )
      }
    </div>
  </Section>

  <Section eyebrow="Wiring" title="How z4j plugs in">
    <div class="grid gap-6 md:grid-cols-2">
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6">
        <h3 class="mb-3 font-semibold">Event capture</h3>
        <p class="text-sm leading-relaxed text-[var(--color-muted)]">
          {engine.eventCapture}
        </p>
      </div>
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6">
        <h3 class="mb-3 font-semibold">Reconciliation</h3>
        <p class="text-sm leading-relaxed text-[var(--color-muted)]">
          {engine.reconcile}
        </p>
      </div>
    </div>
  </Section>

  {
    paired && (
      <Section
        eyebrow="Paired scheduler"
        title={paired.shortName}
        subtitle={paired.tagline}
      >
        <Card
          href={`/schedulers/${paired.slug}`}
          title={paired.name}
          icon={paired.icon}
          logo={paired.logo}
          description={paired.description}
        />
      </Section>
    )
  }

  <Section eyebrow="More engines" title="Other z4j engines">
    <div class="grid gap-4 md:grid-cols-3">
      {
        other.map((e) => (
          <Card
            href={`/engines/${e.slug}`}
            title={e.shortName}
            icon={e.icon}
            logo={e.logo}
            description={e.tagline}
          />
        ))
      }
    </div>
  </Section>

  <CTA
    title={`Try z4j with ${engine.shortName}`}
    primaryHref="/install"
    primaryLabel="Install z4j"
    secondaryHref={engine.docsHref}
    secondaryLabel={`${engine.shortName} docs`}
  />
</BaseLayout>
