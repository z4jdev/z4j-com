---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import PageHero from "../components/PageHero.astro";
import CTA from "../components/CTA.astro";
import {
  PACKAGES,
  RELEASES,
  CATEGORY_ORDER,
  Z4J_HEADLINE_VERSION,
  type PackageRelease,
  type PackageMeta,
} from "../data/packages";

const typeStyle: Record<string, string> = {
  added: "bg-[var(--color-accent)]/15 text-[var(--color-accent)] border-[var(--color-accent)]/30",
  changed: "bg-[var(--color-primary)]/15 text-[var(--color-primary)] border-[var(--color-primary)]/30",
  fixed: "bg-[oklch(0.7_0.15_25)]/15 text-[oklch(0.65_0.2_25)] border-[oklch(0.7_0.15_25)]/30",
  security: "bg-[var(--color-warning)]/20 text-[var(--color-warning)] border-[var(--color-warning)]/30",
  deprecated: "bg-[var(--color-surface-raised)] text-[var(--color-muted)] border-[var(--color-border)]",
  removed: "bg-[var(--color-surface-raised)] text-[var(--color-muted)] border-[var(--color-border)]",
};

// Sort releases newest-first within each package using SemVer-aware compare,
// then by date as tiebreaker.
const sortedReleases: PackageRelease[] = [...RELEASES].sort((a, b) => {
  if (a.package !== b.package) return a.package.localeCompare(b.package);
  return b.version.localeCompare(a.version, undefined, { numeric: true });
});

interface ReleaseCardProps {
  release: PackageRelease;
  pkg: PackageMeta;
}

const cards: ReleaseCardProps[] = sortedReleases
  .map((r) => {
    const pkg = PACKAGES[r.package];
    if (!pkg) return null;
    return { release: r, pkg };
  })
  .filter((x): x is ReleaseCardProps => x !== null)
  // Cross-package: newest releases on top by date desc, then by package name.
  .sort((a, b) => {
    if (a.release.date !== b.release.date) {
      return b.release.date.localeCompare(a.release.date);
    }
    return a.pkg.name.localeCompare(b.pkg.name);
  });

const totalEntries = cards.reduce((sum, c) => sum + c.release.entries.length, 0);

const counts: Record<string, number> = { all: cards.length };
for (const c of cards) {
  counts[c.pkg.category] = (counts[c.pkg.category] ?? 0) + 1;
}

const categories = [{ id: "all", label: "All" }, ...CATEGORY_ORDER];

// Per-package latest summary table at top of page.
const allPackages = CATEGORY_ORDER.flatMap(({ id, label }) =>
  Object.values(PACKAGES)
    .filter((p) => p.category === id)
    .sort((a, b) => a.name.localeCompare(b.name))
    .map((p) => ({ ...p, categoryLabel: label })),
);
---

<BaseLayout
  title="Changelog | z4j releases"
  description="Every z4j package release in one place. Filter by Brain, Core, Frameworks, Engines, or Schedulers. Single source of truth shared with z4j.dev."
  keywords={["z4j changelog", "z4j releases", "z4j v1.0.5", "task queue release notes"]}
>
  <PageHero
    breadcrumb={[{ label: "Changelog" }]}
    title="Every release, spelled out."
    subtitle="One card per package version. Filter by category. Synced with the docs site from one canonical data file."
  />

  <!-- Headline strip -->
  <Section compact>
    <div class="flex flex-wrap items-center justify-between gap-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6">
      <div>
        <div class="font-mono text-[10px] font-semibold uppercase tracking-wider text-[var(--color-muted)]">
          Headline release
        </div>
        <div class="mt-1 flex items-baseline gap-3">
          <span class="font-mono text-3xl font-semibold tracking-tight text-[var(--color-primary)]">v{Z4J_HEADLINE_VERSION}</span>
          <span class="text-sm text-[var(--color-muted)]">brain + agent stack</span>
        </div>
        <p class="mt-2 max-w-xl text-sm leading-relaxed text-[var(--color-muted)]">
          Every package below ships independently. The "headline" version tracks <code class="rounded bg-[var(--color-surface-raised)] px-1.5 py-0.5 font-mono text-xs">z4j-brain</code>, since the brain is the canonical control plane.
        </p>
      </div>
      <dl class="grid grid-cols-2 gap-x-8 gap-y-1 text-sm">
        <div>
          <dt class="font-mono text-[10px] font-semibold uppercase tracking-wider text-[var(--color-muted)]">Packages</dt>
          <dd class="mt-1 text-xl font-semibold">{Object.keys(PACKAGES).length}</dd>
        </div>
        <div>
          <dt class="font-mono text-[10px] font-semibold uppercase tracking-wider text-[var(--color-muted)]">Releases</dt>
          <dd class="mt-1 text-xl font-semibold">{cards.length}</dd>
        </div>
        <div>
          <dt class="font-mono text-[10px] font-semibold uppercase tracking-wider text-[var(--color-muted)]">Entries</dt>
          <dd class="mt-1 text-xl font-semibold">{totalEntries}</dd>
        </div>
      </dl>
    </div>
  </Section>

  <!-- Per-package latest table -->
  <Section compact>
    <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6">
      <h2 class="font-mono text-[10px] font-semibold uppercase tracking-wider text-[var(--color-muted)]">
        Latest of every package
      </h2>
      <div class="mt-4 overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="text-left text-xs uppercase tracking-wider text-[var(--color-muted)]">
            <tr class="border-b border-[var(--color-border)]">
              <th class="py-2 pr-4 font-mono">Package</th>
              <th class="py-2 pr-4 font-mono">Latest</th>
              <th class="py-2 pr-4 font-mono">Released</th>
              <th class="py-2 pr-4 font-mono">Category</th>
              <th class="py-2 pr-4 font-mono">License</th>
              <th class="py-2 pr-4 font-mono">Links</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-[var(--color-border)]/50">
            {allPackages.map((p) => (
              <tr>
                <td class="py-2 pr-4 font-mono text-xs">{p.name}</td>
                <td class="py-2 pr-4 font-mono text-xs font-semibold text-[var(--color-primary)]">{p.latest}</td>
                <td class="py-2 pr-4 text-xs text-[var(--color-muted)]">{p.releaseDate}</td>
                <td class="py-2 pr-4 text-xs">{p.categoryLabel}</td>
                <td class="py-2 pr-4 text-xs">{p.license}</td>
                <td class="py-2 pr-4 text-xs">
                  <a href={p.pypi} class="text-[var(--color-primary)] hover:underline">PyPI</a>
                  <span class="mx-1 text-[var(--color-muted)]">·</span>
                  <a href={p.github} class="text-[var(--color-primary)] hover:underline">GitHub</a>
                  {p.docs && <>
                    <span class="mx-1 text-[var(--color-muted)]">·</span>
                    <a href={p.docs} class="text-[var(--color-primary)] hover:underline">Docs</a>
                  </>}
                  {p.upstream && <>
                    <span class="mx-1 text-[var(--color-muted)]">·</span>
                    <a href={p.upstream} class="text-[var(--color-muted)] hover:underline">Upstream</a>
                  </>}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </Section>

  <!-- Per-release cards -->
  <Section compact>
    <div
      id="changelog-root"
      data-active-category="all"
      class="space-y-10"
    >
      <div class="sticky top-16 z-10 -mx-4 border-y border-[var(--color-border)] bg-[var(--color-bg)]/90 px-4 py-3 backdrop-blur md:-mx-6 md:px-6">
        <div class="flex items-center gap-3 overflow-x-auto">
          <span class="shrink-0 font-mono text-[10px] font-semibold uppercase tracking-wider text-[var(--color-muted)]">
            Filter:
          </span>
          <div role="tablist" class="flex items-center gap-2">
            {categories.map((cat) => (
              <button
                type="button"
                role="tab"
                data-category-filter={cat.id}
                aria-selected={cat.id === "all" ? "true" : "false"}
                class="inline-flex shrink-0 items-center gap-1.5 rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-1 text-xs font-medium text-[var(--color-muted)] transition-colors hover:border-[var(--color-primary)]/40 hover:text-[var(--color-fg)] aria-selected:border-[var(--color-primary)] aria-selected:bg-[var(--color-primary)] aria-selected:text-white"
              >
                {cat.label}
                <span class="rounded-full bg-[var(--color-bg)]/30 px-1.5 py-0.5 font-mono text-[10px] font-semibold tabular-nums aria-selected:bg-white/20">
                  {counts[cat.id] ?? 0}
                </span>
              </button>
            ))}
          </div>
        </div>
      </div>

      <ol class="space-y-6">
        {cards.map(({ release, pkg }) => (
          <li
            data-component={`${pkg.name}-${release.version}`}
            data-category={pkg.category}
            class="changelog-card rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)]/60"
          >
            <header class="flex flex-wrap items-baseline justify-between gap-3 border-b border-[var(--color-border)] px-6 py-4">
              <div class="flex items-baseline gap-3">
                <a href={pkg.pypi} class="font-mono text-base font-semibold text-[var(--color-fg)] hover:text-[var(--color-primary)]">
                  {pkg.name}
                </a>
                <span class="rounded-full bg-[var(--color-surface-raised)] px-2 py-0.5 font-mono text-[10px] font-semibold uppercase tracking-wider text-[var(--color-muted)]">
                  {CATEGORY_ORDER.find((c) => c.id === pkg.category)?.label ?? pkg.category}
                </span>
                {release.version === pkg.latest && (
                  <span class="rounded-full bg-[var(--color-accent)]/15 px-2 py-0.5 font-mono text-[10px] font-semibold uppercase tracking-wider text-[var(--color-accent)]">
                    latest
                  </span>
                )}
              </div>
              <div class="flex items-baseline gap-3 text-xs text-[var(--color-muted)]">
                <span class="font-mono font-semibold text-[var(--color-primary)]">v{release.version}</span>
                <span>{release.date}</span>
              </div>
            </header>
            <ul class="divide-y divide-[var(--color-border)]/50">
              {release.entries.map((e) => (
                <li class="flex items-start gap-3 px-6 py-3">
                  <span class={`mt-0.5 inline-flex shrink-0 items-center rounded-md border px-2 py-0.5 font-mono text-[10px] font-semibold uppercase tracking-wider ${typeStyle[e.type]}`}>
                    {e.type}
                  </span>
                  <span class="text-sm leading-relaxed">{e.summary}</span>
                </li>
              ))}
            </ul>
          </li>
        ))}
      </ol>

      <p id="changelog-empty" hidden class="rounded-lg border border-dashed border-[var(--color-border)] bg-[var(--color-surface)] p-6 text-center text-sm text-[var(--color-muted)]">
        No entries match this filter.
      </p>
    </div>
  </Section>

  <CTA
    title="Browse the source"
    subtitle="Each package has its own GitHub repo and PyPI page. Click the package name on any card above."
    primaryHref="https://github.com/z4jdev"
    primaryLabel="z4jdev on GitHub"
    secondaryHref="https://pypi.org/user/z4jdev/"
    secondaryLabel="z4jdev on PyPI"
  />
</BaseLayout>

<script>
  const root = document.getElementById("changelog-root");
  const emptyState = document.getElementById("changelog-empty");
  if (root) {
    const buttons = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-category-filter]"));
    const cards = Array.from(root.querySelectorAll<HTMLLIElement>(".changelog-card"));

    function apply(category: string) {
      root!.setAttribute("data-active-category", category);
      buttons.forEach((b) => {
        b.setAttribute(
          "aria-selected",
          b.getAttribute("data-category-filter") === category ? "true" : "false",
        );
      });
      let visible = 0;
      cards.forEach((card) => {
        const match = category === "all" || card.getAttribute("data-category") === category;
        if (match) {
          card.removeAttribute("hidden");
          visible++;
        } else {
          card.setAttribute("hidden", "");
        }
      });
      if (emptyState) {
        if (visible === 0) emptyState.removeAttribute("hidden");
        else emptyState.setAttribute("hidden", "");
      }
    }

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const cat = btn.getAttribute("data-category-filter") ?? "all";
        apply(cat);
      });
    });
  }
</script>
