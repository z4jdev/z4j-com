---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/Section.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import Icon from "../../components/Icon.astro";
import CTA from "../../components/CTA.astro";
import { COMPETITORS } from "../../data/competitors";

export function getStaticPaths() {
  return COMPETITORS.map((c) => ({
    params: { slug: c.slug },
    props: { competitor: c },
  }));
}

const { competitor } = Astro.props;
const others = COMPETITORS.filter((c) => c.slug !== competitor.slug);

const metaTitle = `z4j vs. ${competitor.name} | full comparison`;
const metaDescription = `${competitor.tagline} A capability-by-capability look at z4j and ${competitor.name}, plus honest trade-offs.`;
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  keywords={[`z4j vs ${competitor.name}`, competitor.name, "task queue dashboard comparison"]}
  breadcrumbs={[
    { name: "Compare", href: "/compare" },
    { name: competitor.name, href: `/compare/${competitor.slug}` },
  ]}
>
  <Section compact>
    <Breadcrumb items={[
      { label: "Compare", href: "/compare" },
      { label: competitor.name },
    ]} />
    <div class="max-w-3xl">
      <div class="mb-3 inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-1 text-xs font-medium text-[var(--color-muted)]">
        <span>z4j</span>
        <span class="text-[var(--color-muted)]/60">vs.</span>
        <span class="text-[var(--color-fg)]">{competitor.name}</span>
      </div>
      <h1 class="text-4xl font-bold tracking-tight md:text-5xl">
        {competitor.tagline}
      </h1>
      <dl class="mt-6 grid max-w-2xl grid-cols-2 gap-x-6 gap-y-3 text-sm sm:grid-cols-3">
        <div>
          <dt class="text-[var(--color-muted)]">Scope</dt>
          <dd class="mt-0.5 font-medium">{competitor.scope}</dd>
        </div>
        <div>
          <dt class="text-[var(--color-muted)]">Positioning</dt>
          <dd class="mt-0.5 font-medium">{competitor.positioning}</dd>
        </div>
        <div>
          <dt class="text-[var(--color-muted)]">License</dt>
          <dd class="mt-0.5 font-medium">{competitor.licensing}</dd>
        </div>
      </dl>
      {competitor.upstreamUrl && (
        <a
          href={competitor.upstreamUrl}
          rel="nofollow noopener"
          target="_blank"
          class="mt-5 inline-flex items-center gap-1.5 text-sm font-medium text-[var(--color-primary)] hover:underline"
        >
          {competitor.name} upstream project
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M1 5h8m0 0L5 1m4 4L5 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      )}
    </div>
  </Section>

  <Section eyebrow={`what ${competitor.name} does well`} title="Credit where it's due">
    <div class="grid gap-3 md:grid-cols-2">
      {competitor.pros.map((p) => (
        <div class="flex items-start gap-3 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-4">
          <Icon name="check" size={16} class="mt-0.5 shrink-0 text-[var(--color-accent)]" />
          <span class="text-sm leading-relaxed">{p}</span>
        </div>
      ))}
    </div>
  </Section>

  <Section eyebrow="capability matrix" title={`z4j vs. ${competitor.name}, feature by feature`}>
    <div class="overflow-x-auto rounded-xl border border-[var(--color-border)]">
      <table class="w-full min-w-[640px] text-sm">
        <thead class="bg-[var(--color-surface)]">
          <tr class="text-left">
            <th class="sticky left-0 bg-[var(--color-surface)] px-4 py-3 font-semibold">Capability</th>
            <th class="px-4 py-3 font-semibold">{competitor.name}</th>
            <th class="px-4 py-3 font-semibold text-[var(--color-primary)]">z4j</th>
          </tr>
        </thead>
        <tbody>
          {
            competitor.capabilityTable.map((r) => (
              <tr class="border-t border-[var(--color-border)] transition-colors hover:bg-[var(--color-surface)]/40">
                <td class="sticky left-0 bg-[var(--color-bg)] px-4 py-3 font-medium">{r.cap}</td>
                <td class="px-4 py-3">
                  <span class="flex items-start gap-1.5 text-[var(--color-muted)]">
                    <Icon
                      name={r.theirsOK ? "check" : "x"}
                      size={14}
                      class={`mt-0.5 shrink-0 ${r.theirsOK ? "text-[var(--color-accent)]" : "text-[var(--color-muted)]/60"}`}
                    />
                    <span>{r.theirs}</span>
                  </span>
                </td>
                <td class="px-4 py-3">
                  <span class="flex items-start gap-1.5 text-[var(--color-fg)]">
                    <Icon
                      name={r.z4jOK === false ? "x" : "check"}
                      size={14}
                      class={`mt-0.5 shrink-0 ${r.z4jOK === false ? "text-[var(--color-muted)]/60" : "text-[var(--color-accent)]"}`}
                    />
                    <span>{r.z4j}</span>
                  </span>
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </Section>

  {
    competitor.migrationSteps && competitor.migrationSteps.length > 0 && (
      <Section
        eyebrow="migration guide"
        title={`Cut over from ${competitor.name} in a week (or a weekend)`}
      >
        <ol class="grid max-w-4xl gap-4 md:grid-cols-2">
          {competitor.migrationSteps.map((s, i) => (
            <li class="flex gap-4 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5">
              <span class="inline-flex size-8 shrink-0 items-center justify-center rounded-full bg-[var(--color-primary)] text-sm font-bold text-white">
                {i + 1}
              </span>
              <div class="min-w-0">
                <h3 class="font-semibold">{s.title}</h3>
                <p class="mt-1 text-sm leading-relaxed text-[var(--color-muted)]">{s.body}</p>
              </div>
            </li>
          ))}
        </ol>
      </Section>
    )
  }

  <Section eyebrow="honest trade-offs" title="Where we don't win">
    <div class="max-w-3xl space-y-4 leading-relaxed text-[var(--color-muted)]">
      {competitor.honestTradeoffs.map((t) => (
        <p>{t}</p>
      ))}
    </div>
  </Section>

  {
    others.length > 0 && (
      <Section eyebrow="other comparisons" title="Compared to other dashboards">
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {others.map((c) => (
            <a
              href={`/compare/${c.slug}`}
              class="group flex flex-col rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 transition-colors hover:border-[var(--color-primary)]/40"
            >
              <div class="font-mono text-[10px] font-semibold uppercase tracking-wider text-[var(--color-muted)]">
                vs. {c.name}
              </div>
              <h3 class="mt-1 text-base font-semibold tracking-tight">{c.name}</h3>
              <p class="mt-1 text-sm leading-relaxed text-[var(--color-muted)]">{c.tagline}</p>
              <span class="mt-auto inline-flex items-center gap-1 pt-4 text-sm font-semibold text-[var(--color-primary)]">
                Compare
                <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true" class="transition-transform group-hover:translate-x-0.5"><path d="M1 5h8m0 0L5 1m4 4L5 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </a>
          ))}
        </div>
      </Section>
    )
  }

  <CTA
    title={`Try z4j alongside ${competitor.name}, no migration required`}
    subtitle="Run both for a week. Compare. Decide."
    primaryHref="/install"
    primaryLabel="Install z4j"
    secondaryHref={competitor.ctaSecondaryHref ?? "/compare"}
    secondaryLabel={competitor.ctaSecondaryLabel ?? "All comparisons"}
  />
</BaseLayout>
