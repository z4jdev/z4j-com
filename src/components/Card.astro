---
import Icon from "./Icon.astro";

interface Props {
  href?: string;
  title: string;
  icon?: string;
  logo?: string;
  description?: string;
  tag?: string;
  class?: string;
}
const { href, title, icon, logo, description, tag, class: className } = Astro.props;
const Root = href ? "a" : "div";
---

<Root
  href={href}
  class:list={[
    "group relative flex flex-col gap-3 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 transition-all",
    href &&
      "hover:-translate-y-0.5 hover:border-[var(--color-primary)]/40 hover:shadow-lg hover:shadow-[var(--color-primary)]/5",
    className,
  ]}
>
  <div class="flex items-center justify-between gap-2">
    <div class="flex items-center gap-3">
      {logo ? (
        <span class="inline-flex size-14 items-center justify-center rounded-xl bg-[var(--color-surface-raised)] p-2">
          <img src={logo} alt={title} class="size-10 object-contain" />
        </span>
      ) : icon ? (
        <span class="inline-flex size-14 items-center justify-center rounded-xl bg-[var(--color-primary)]/10 text-[var(--color-primary)]">
          <Icon name={icon} size={28} />
        </span>
      ) : null}
      <h3 class="text-base font-semibold tracking-tight">{title}</h3>
    </div>
    {tag && (
      <span class="rounded-full bg-[var(--color-surface-raised)] px-2.5 py-0.5 text-[10px] font-semibold text-[var(--color-muted)]">
        {tag}
      </span>
    )}
  </div>
  {description && (
    <p class="text-sm leading-relaxed text-[var(--color-muted)]">
      {description}
    </p>
  )}
  <slot />
  {
    href && (
      <span class="mt-auto inline-flex items-center gap-1 text-xs font-medium text-[var(--color-primary)] opacity-0 transition-opacity group-hover:opacity-100">
        Learn more
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
          <path d="M1 5h8m0 0L5 1m4 4L5 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </span>
    )
  }
</Root>
