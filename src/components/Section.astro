---
interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  compact?: boolean;
  as?: "h1" | "h2";
  class?: string;
}
const {
  id,
  eyebrow,
  title,
  subtitle,
  compact = false,
  as = "h2",
  class: className,
} = Astro.props;
const HeadingTag = as;
---

<section id={id} class:list={[
  "mx-auto w-full max-w-6xl px-4 md:px-6",
  compact ? "py-10 md:py-14" : "py-16 md:py-24",
  className,
]}>
  {
    (eyebrow || title || subtitle) && (
      <header class="mb-10 max-w-3xl">
        {eyebrow && (
          <div class="mb-2 inline-flex items-center rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-1 text-xs font-medium text-[var(--color-accent)]">
            {eyebrow}
          </div>
        )}
        {title && (
          <HeadingTag class:list={[
            as === "h1"
              ? "text-4xl font-bold tracking-tight md:text-5xl"
              : "text-3xl font-semibold tracking-tight md:text-4xl",
          ]}>
            {title}
          </HeadingTag>
        )}
        {subtitle && (
          <p class="mt-3 text-lg leading-relaxed text-[var(--color-muted)]">
            {subtitle}
          </p>
        )}
      </header>
    )
  }
  <slot />
</section>
