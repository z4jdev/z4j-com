const b = brands[name];
const displayLabel = label ?? b.label;
---

<span
  class:list={[
    "inline-flex items-center gap-1.5 rounded-md border px-2 py-1 text-[11px] font-semibold",
    className,
  ]}
  style={`border-color: color-mix(in oklch, ${b.color} 30%, transparent); background-color: color-mix(in oklch, ${b.color} 8%, transparent); color: ${b.color};`}
>
  <svg
    width={size}
    height={size}
    viewBox={b.viewBox}
    fill="currentColor"
    aria-hidden="true"
    class="shrink-0"
  >
    {b.paths.map((d) => <path d={d} />)}
  </svg>
  <span class="text-[var(--color-fg)]">{displayLabel}</span>
</span>
