---
interface Props {
  lang?: string;
  filename?: string;
}
const { lang, filename } = Astro.props;
---

<figure class="min-w-0 max-w-full rounded-lg border border-[var(--color-border)] bg-[var(--color-code-bg)]">
  {
    (filename || lang) && (
      <figcaption class="flex items-center justify-between gap-3 border-b border-white/10 px-4 py-2 text-xs text-slate-400">
        <span class="min-w-0 truncate font-mono">{filename ?? ""}</span>
        {lang && <span class="shrink-0 rounded bg-white/10 px-2 py-0.5">{lang}</span>}
      </figcaption>
    )
  }
  <pre class="min-w-0 max-w-full overflow-x-auto p-4 text-xs leading-relaxed text-slate-200 sm:text-sm"><code><slot /></code></pre>
</figure>
