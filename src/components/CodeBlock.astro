---
interface Props {
  lang?: string;
  filename?: string;
}
const { lang, filename } = Astro.props;
---

<figure class="rounded-lg border border-[var(--color-border)] bg-[var(--color-code-bg)]">
  {
    (filename || lang) && (
      <figcaption class="flex items-center justify-between border-b border-white/10 px-4 py-2 text-xs text-slate-400">
        <span class="font-mono">{filename ?? ""}</span>
        {lang && <span class="rounded bg-white/10 px-2 py-0.5">{lang}</span>}
      </figcaption>
    )
  }
  <pre class="overflow-x-auto p-4 text-sm leading-relaxed text-slate-200"><code><slot /></code></pre>
</figure>
