---
/**
 * Cookie consent banner for Google Analytics 4 (Consent Mode v2).
 *
 * Renders nothing on first paint for visitors who have already
 * chosen (granted or denied). For visitors with no recorded
 * choice, a small bottom-corner banner asks them to Accept or
 * Decline analytics. The choice persists in localStorage under
 * the key `z4j-consent` so the banner does not reappear.
 *
 * gtag('consent', 'default', { ... 'denied' }) is set in
 * BaseLayout BEFORE the gtag.js script tag loads, so GA only
 * activates cookies + advertising features after explicit Accept.
 * Consent Mode v2 still sends cookieless pings even in the
 * default-denied state, so basic pageview counts surface in
 * GA4 reports for visitors who never interact with the banner.
 */
---
<div
  id="consent-banner"
  role="dialog"
  aria-labelledby="consent-banner-title"
  aria-describedby="consent-banner-desc"
  class="consent-banner"
  hidden
>
  <div class="consent-banner-inner">
    <div class="min-w-0 flex-1">
      <p id="consent-banner-title" class="text-sm font-semibold text-[var(--color-fg)]">
        We use analytics cookies
      </p>
      <p id="consent-banner-desc" class="mt-1 text-xs leading-relaxed text-[var(--color-muted)]">
        Anonymous pageview + referrer data via Google Analytics so
        we can see which content is useful. No advertising, no
        cross-site tracking. You can change your mind any time.
      </p>
    </div>
    <div class="consent-banner-actions">
      <button
        type="button"
        id="consent-decline"
        class="rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-1.5 text-xs font-semibold text-[var(--color-fg)] hover:border-[var(--color-primary)]/40 transition-colors"
      >
        Decline
      </button>
      <button
        type="button"
        id="consent-accept"
        class="rounded-md bg-[var(--color-primary)] px-3 py-1.5 text-xs font-semibold text-white hover:opacity-90 transition-opacity"
      >
        Accept
      </button>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var KEY = "z4j-consent";
    var banner = document.getElementById("consent-banner");
    if (!banner) return;
    var stored;
    try { stored = localStorage.getItem(KEY); } catch (e) {}
    // Show only when no prior choice. The default for GA stays
    // 'denied' until the user explicitly Accepts.
    if (stored !== "granted" && stored !== "denied") {
      banner.hidden = false;
    }
    function persist(choice) {
      try { localStorage.setItem(KEY, choice); } catch (e) {}
      if (typeof gtag === "function") {
        gtag("consent", "update", {
          analytics_storage: choice === "granted" ? "granted" : "denied",
        });
      }
      banner.hidden = true;
    }
    var acceptBtn = document.getElementById("consent-accept");
    var declineBtn = document.getElementById("consent-decline");
    if (acceptBtn) acceptBtn.addEventListener("click", function () { persist("granted"); });
    if (declineBtn) declineBtn.addEventListener("click", function () { persist("denied"); });
  })();
</script>

<style>
  /* Bottom-right corner positioned banner. Stays out of the way
     of content but is clearly visible. Slides in subtly on first
     paint via opacity + transform; respects reduced-motion. */
  .consent-banner {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 50;
    max-width: 28rem;
    border-radius: 0.75rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    padding: 1rem 1.125rem;
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.06),
      0 8px 32px -12px rgba(0, 0, 0, 0.18);
    animation: consent-banner-in 350ms cubic-bezier(0.4, 0, 0.2, 1) both;
  }
  .consent-banner-inner {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }
  .consent-banner-actions {
    display: flex;
    gap: 0.5rem;
    justify-content: flex-end;
  }
  @media (min-width: 640px) {
    .consent-banner-inner {
      flex-direction: row;
      align-items: center;
      gap: 1.25rem;
    }
    .consent-banner-actions {
      justify-content: flex-start;
    }
  }
  @keyframes consent-banner-in {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .consent-banner { animation: none; }
  }
</style>
