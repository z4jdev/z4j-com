---
/**
 * Cookie consent banner for Google Analytics 4 (Consent Mode v2),
 * GEO-TARGETED to EEA / UK / Switzerland visitors only.
 *
 * Decision flow on first visit (no localStorage[z4j-consent] yet):
 *
 *   1. Fetch /cdn-cgi/trace (free Cloudflare endpoint on every
 *      Pages site) to get the visitor's country code (loc=XX).
 *   2. If XX is in the EEA list (27 EU + Iceland + Liechtenstein
 *      + Norway), in the UK (GB), or in Switzerland (CH):
 *        -> show the banner; consent stays denied until user
 *           clicks Accept.
 *   3. Otherwise (US, Canada, Asia, anywhere else):
 *        -> auto-grant analytics_storage + persist 'granted' in
 *           localStorage. Banner never appears. Full GA tracking
 *           engages immediately.
 *   4. If the geo lookup fails (network error, unexpected
 *      response): SAFE DEFAULT = show the banner. Never
 *      auto-grant when we cannot determine jurisdiction.
 *
 * Returning visitors (localStorage[z4j-consent] is set) skip the
 * geo lookup entirely and respect their persisted choice.
 *
 * Why this is legal: GDPR + UK PECR + EEA cookie laws apply
 * based on where the data subject is located. US visitors have
 * no federal opt-in requirement (CCPA's "Do Not Sell" is a
 * footer-link, not a banner). IP geolocation via Cloudflare's
 * own endpoint is the industry-standard proxy for jurisdiction
 * (~95% accurate). Stripe / Vercel / GitHub / Linear all do
 * exactly this.
 *
 * gtag('consent', 'default', { ... 'denied' }) is set in
 * BaseLayout BEFORE the gtag.js script tag loads, so on first
 * paint GA is in cookieless-ping mode regardless of geo. The
 * country-detect script then either auto-grants (non-EEA) or
 * waits for the user (EEA + banner shown).
 */
---
<div
  id="consent-banner"
  role="dialog"
  aria-labelledby="consent-banner-title"
  aria-describedby="consent-banner-desc"
  class="consent-banner"
  hidden
>
  <div class="consent-banner-inner">
    <div class="min-w-0 flex-1">
      <p id="consent-banner-title" class="text-sm font-semibold text-[var(--color-fg)]">
        We use analytics cookies
      </p>
      <p id="consent-banner-desc" class="mt-1 text-xs leading-relaxed text-[var(--color-muted)]">
        Anonymous pageview + referrer data via Google Analytics so
        we can see which content is useful. No advertising, no
        cross-site tracking. You can change your mind any time.
      </p>
    </div>
    <div class="consent-banner-actions">
      <button
        type="button"
        id="consent-decline"
        class="rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-1.5 text-xs font-semibold text-[var(--color-fg)] hover:border-[var(--color-primary)]/40 transition-colors"
      >
        Decline
      </button>
      <button
        type="button"
        id="consent-accept"
        class="rounded-md bg-[var(--color-primary)] px-3 py-1.5 text-xs font-semibold text-white hover:opacity-90 transition-opacity"
      >
        Accept
      </button>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var KEY = "z4j-consent";
    // 27 EU + 3 EEA-non-EU (IS, LI, NO) + UK (GB) + Switzerland
    // (CH). All jurisdictions where prior consent is required for
    // non-essential cookies / tracking. Sorted alphabetically for
    // readability.
    var EEA = {
      AT:1, BE:1, BG:1, CH:1, CY:1, CZ:1, DE:1, DK:1, EE:1, ES:1,
      FI:1, FR:1, GB:1, GR:1, HR:1, HU:1, IE:1, IS:1, IT:1, LI:1,
      LT:1, LU:1, LV:1, MT:1, NL:1, NO:1, PL:1, PT:1, RO:1, SE:1,
      SI:1, SK:1
    };
    var banner = document.getElementById("consent-banner");
    if (!banner) return;

    function persist(choice) {
      try { localStorage.setItem(KEY, choice); } catch (e) {}
      if (typeof gtag === "function") {
        gtag("consent", "update", {
          analytics_storage: choice === "granted" ? "granted" : "denied",
        });
      }
      banner.hidden = true;
    }
    function showBanner() { banner.hidden = false; }

    // Wire button handlers up front so they work regardless of
    // which branch (geo / persisted) hides or shows the banner.
    var acceptBtn = document.getElementById("consent-accept");
    var declineBtn = document.getElementById("consent-decline");
    if (acceptBtn) acceptBtn.addEventListener("click", function () { persist("granted"); });
    if (declineBtn) declineBtn.addEventListener("click", function () { persist("denied"); });

    // Returning visitor: respect their prior choice, skip geo.
    var stored;
    try { stored = localStorage.getItem(KEY); } catch (e) {}
    if (stored === "granted" || stored === "denied") {
      // Choice was already applied at consent-default time in
      // BaseLayout (the inline script reads localStorage and
      // updates consent before gtag('config') runs). Nothing
      // more to do here; banner stays hidden.
      return;
    }

    // First-visit path: geo-check via Cloudflare's free
    // /cdn-cgi/trace endpoint (served from every CF-fronted
    // origin, no CORS issues, returns small text body in <50ms
    // typically). Default-denied persists during the lookup.
    fetch("/cdn-cgi/trace", { cache: "no-store" })
      .then(function (r) { return r.ok ? r.text() : Promise.reject(r.status); })
      .then(function (text) {
        var m = text.match(/loc=([A-Z]{2})/);
        var country = m ? m[1] : null;
        if (country && !EEA[country]) {
          // Non-EEA visitor: auto-grant + persist so future
          // page navigations skip the geo lookup entirely.
          persist("granted");
        } else {
          // EEA visitor (or country undetermined): show banner,
          // wait for explicit choice. Consent stays denied.
          showBanner();
        }
      })
      .catch(function () {
        // Network failed / Cloudflare returned non-2xx: SAFE
        // DEFAULT = show banner. Never auto-grant when we cannot
        // determine jurisdiction.
        showBanner();
      });
  })();
</script>

<style>
  /* Bottom-right corner positioned banner. Stays out of the way
     of content but is clearly visible. Slides in subtly on first
     paint via opacity + transform; respects reduced-motion. */
  .consent-banner {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 50;
    max-width: 28rem;
    border-radius: 0.75rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    padding: 1rem 1.125rem;
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.06),
      0 8px 32px -12px rgba(0, 0, 0, 0.18);
    animation: consent-banner-in 350ms cubic-bezier(0.4, 0, 0.2, 1) both;
  }
  .consent-banner-inner {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }
  .consent-banner-actions {
    display: flex;
    gap: 0.5rem;
    justify-content: flex-end;
  }
  @media (min-width: 640px) {
    .consent-banner-inner {
      flex-direction: row;
      align-items: center;
      gap: 1.25rem;
    }
    .consent-banner-actions {
      justify-content: flex-start;
    }
  }
  @keyframes consent-banner-in {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .consent-banner { animation: none; }
  }
</style>
