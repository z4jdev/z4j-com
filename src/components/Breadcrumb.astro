---
interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="mb-8">
  <ol class="flex items-center gap-1.5 text-sm text-[var(--color-muted)]">
    <li>
      <a href="/" class="hover:text-[var(--color-fg)] transition-colors">Home</a>
    </li>
    {items.map((item, i) => (
      <li class="flex items-center gap-1.5">
        <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="opacity-40"><path d="M6 4l4 4-4 4"/></svg>
        {item.href ? (
          <a href={item.href} class="hover:text-[var(--color-fg)] transition-colors">{item.label}</a>
        ) : (
          <span class="text-[var(--color-fg)] font-medium">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
