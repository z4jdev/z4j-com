---
/**
 * Site search.
 *
 * The button opens a dialog with the Pagefind UI mounted inside. Pagefind
 * is built by `pagefind --site dist` after `astro build`, so the
 * /pagefind/ assets are static - no runtime server needed. UI loads
 * lazily on the first open so users who never search pay zero JS or
 * CSS cost up front.
 *
 * Keyboard: Cmd/Ctrl + K toggles the modal anywhere on the site.
 */
---

<site-search class="contents">
  <button
    type="button"
    data-open-search
    aria-label="Search"
    title="Search (Ctrl+K)"
    aria-keyshortcuts="Control+K"
    class="inline-flex size-9 items-center justify-center rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-muted)] transition-colors hover:border-[var(--color-primary)]/40 hover:text-[var(--color-fg)]"
  >
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="11" cy="11" r="7"/>
      <path d="m21 21-4.3-4.3"/>
    </svg>
  </button>

  <dialog
    data-search-dialog
    aria-label="Search z4j.com"
    class="w-full max-w-2xl rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-0 text-[var(--color-fg)] shadow-2xl backdrop:bg-black/60 backdrop:backdrop-blur-sm"
  >
    <div class="flex flex-col">
      <div class="flex items-center justify-between border-b border-[var(--color-border)] px-4 py-3">
        <span class="text-xs font-semibold uppercase tracking-wider text-[var(--color-muted)]">Search z4j.com</span>
        <button
          type="button"
          data-close-search
          aria-label="Close search"
          class="inline-flex size-7 items-center justify-center rounded text-[var(--color-muted)] transition-colors hover:bg-[var(--color-surface-raised)] hover:text-[var(--color-fg)]"
        >
          <svg width="14" height="14" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M5 5l10 10M15 5L5 15" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
      <div id="z4j-search" class="p-4"></div>
      <p data-search-fallback hidden class="px-4 pb-4 text-sm text-[var(--color-muted)]">
        Search index is built at deploy time. It is not available in this dev preview.
      </p>
    </div>
  </dialog>
</site-search>

<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />

<style>
  /* Tune Pagefind's CSS variables to fit the z4j.com palette. */
  #z4j-search {
    --pagefind-ui-scale: 0.85;
    --pagefind-ui-primary: var(--color-primary);
    --pagefind-ui-text: var(--color-fg);
    --pagefind-ui-background: var(--color-surface);
    --pagefind-ui-border: var(--color-border);
    --pagefind-ui-tag: var(--color-surface-raised);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 8px;
    --pagefind-ui-image-border-radius: 8px;
    --pagefind-ui-image-box-ratio: 3 / 2;
    --pagefind-ui-font: var(--font-sans, ui-sans-serif, system-ui, sans-serif);
  }

  dialog[data-search-dialog] {
    /* Center the dialog with predictable spacing across browsers. */
    margin: 8vh auto auto;
    max-height: 80vh;
    overflow: auto;
  }
  dialog[data-search-dialog]:not([open]) {
    display: none;
  }
</style>

<script>
  class SiteSearch extends HTMLElement {
    connectedCallback() {
      const dialog = this.querySelector("dialog[data-search-dialog]") as HTMLDialogElement | null;
      const openButtons = this.querySelectorAll<HTMLButtonElement>(
        "button[data-open-search]",
      );
      const closeButton = this.querySelector<HTMLButtonElement>("button[data-close-search]");
      const fallback = this.querySelector<HTMLElement>("[data-search-fallback]");
      if (!dialog) return;

      let mounted = false;

      const mount = async () => {
        if (mounted) return;
        try {
          await loadScriptOnce("/pagefind/pagefind-ui.js");
          // PagefindUI is exposed on the global window when the script loads.
          const Ctor = (window as unknown as { PagefindUI?: new (opts: unknown) => unknown }).PagefindUI;
          if (!Ctor) throw new Error("PagefindUI did not register on window");
          new Ctor({
            element: "#z4j-search",
            showImages: false,
            showSubResults: true,
            resetStyles: false,
            translations: { placeholder: "Search z4j.com" },
          });
          mounted = true;
        } catch (err) {
          if (fallback) fallback.hidden = false;
          // eslint-disable-next-line no-console
          console.warn("z4j search: pagefind UI unavailable", err);
        }
      };

      const open = () => {
        if (!dialog.open) dialog.showModal();
        const input = dialog.querySelector<HTMLInputElement>(".pagefind-ui__search-input");
        if (input) {
          input.focus();
        } else {
          // First open: mount, then focus once the input is in the DOM.
          mount().then(() => {
            const i = dialog.querySelector<HTMLInputElement>(".pagefind-ui__search-input");
            if (i) i.focus();
          });
        }
      };

      const close = () => {
        if (dialog.open) dialog.close();
      };

      openButtons.forEach((btn) => btn.addEventListener("click", open));
      closeButton?.addEventListener("click", close);

      // Click outside the inner panel closes the dialog.
      dialog.addEventListener("click", (event) => {
        if (event.target === dialog) close();
      });

      // Cmd/Ctrl + K toggles the search dialog from anywhere.
      document.addEventListener("keydown", (event) => {
        if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === "k") {
          event.preventDefault();
          if (dialog.open) close();
          else open();
        }
      });
    }
  }

  function loadScriptOnce(src: string): Promise<void> {
    return new Promise((resolve, reject) => {
      const existing = document.querySelector<HTMLScriptElement>(`script[data-src="${src}"]`);
      if (existing) {
        if (existing.dataset.loaded === "true") return resolve();
        existing.addEventListener("load", () => resolve());
        existing.addEventListener("error", () => reject(new Error("script load failed")));
        return;
      }
      const tag = document.createElement("script");
      tag.src = src;
      tag.dataset.src = src;
      tag.async = true;
      tag.addEventListener("load", () => {
        tag.dataset.loaded = "true";
        resolve();
      });
      tag.addEventListener("error", () => reject(new Error("script load failed")));
      document.head.appendChild(tag);
    });
  }

  customElements.define("site-search", SiteSearch);
</script>
