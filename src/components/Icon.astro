---
interface Props {
  name: string;
  size?: number;
  class?: string;
}

const { name, size = 24, class: className = "" } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  class:list={[className]}
  aria-hidden="true"
>
  {/* Engines */}
  {name === "celery" && <><circle cx="12" cy="12" r="4"/><path d="M12 2v4m0 12v4M2 12h4m12 0h4m-3.5-7.5-2.8 2.8m-5.4 5.4-2.8 2.8m0-11.2 2.8 2.8m5.4 5.4 2.8 2.8"/></>}
  {name === "rq" && <><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M7 8h10M7 12h6M7 16h8"/></>}
  {name === "dramatiq" && <><circle cx="12" cy="8" r="5"/><path d="M3 21v-1a7 7 0 0 1 7-7h4a7 7 0 0 1 7 7v1"/></>}
  {name === "huey" && <><path d="M12 2 L15 8 L21 9 L17 14 L18 20 L12 17 L6 20 L7 14 L3 9 L9 8 Z"/></>}
  {name === "arq" && <><path d="M13 2 L3 14h9l-1 8 10-12h-9l1-8z"/></>}
  {name === "taskiq" && <><path d="M4 5h16M4 5v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V5M9 9h6M9 13h4"/></>}

  {/* Frameworks */}
  {name === "django" && <><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/><path d="M12 6v8l6 3"/></>}
  {name === "flask" && <><path d="M9 2h6M12 2v4M8 6h8l2 4-3 8H9L6 10l2-4z"/><path d="M9 14h6"/></>}
  {name === "fastapi" && <><path d="M13 2 L3 14h9l-1 8 10-12h-9l1-8z"/></>}

  {/* Features */}
  {name === "unified-actions" && <><path d="M4 12h16M12 4v16"/><circle cx="12" cy="12" r="3"/></>}
  {name === "reconciliation" && <><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M3 21v-5h5"/></>}
  {name === "trends" && <><path d="M3 20h18"/><path d="M3 20V4"/><path d="M6 16l4-4 4 2 4-6"/></>}
  {name === "dag" && <><circle cx="12" cy="4" r="2"/><circle cx="6" cy="14" r="2"/><circle cx="18" cy="14" r="2"/><circle cx="12" cy="20" r="2"/><path d="M12 6v4M8.5 12.5 10 10M15.5 12.5 14 10M12 18v-2M8 15.5l2.5 2.5M16 15.5l-2.5 2.5"/></>}
  {name === "rbac" && <><path d="M12 2 L20 7v5c0 5.5-3.8 10.7-8 12-4.2-1.3-8-6.5-8-12V7l8-5z"/><path d="M9 12l2 2 4-4"/></>}
  {name === "invitations" && <><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></>}
  {name === "password-reset" && <><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/><circle cx="12" cy="16" r="1"/></>}
  {name === "redaction" && <><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 3v18"/><path d="m15 13-3 3-3-3"/></>}
  {name === "audit-log" && <><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M16 13H8M16 17H8M10 9H8"/></>}
  {name === "rate-limiting" && <><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></>}
  {name === "worker-restart" && <><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M3 21v-5h5"/></>}
  {name === "realtime" && <><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></>}
  {name === "notifications" && <><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></>}

  {/* Security */}
  {name === "shield" && <><path d="M12 2 L20 7v5c0 5.5-3.8 10.7-8 12-4.2-1.3-8-6.5-8-12V7l8-5z"/></>}
  {name === "lock" && <><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></>}
  {name === "key" && <><circle cx="7.5" cy="15.5" r="5.5"/><path d="m21 2-9.3 9.3M15 7l3 3"/></>}
  {name === "fingerprint" && <><path d="M2 12C2 6.5 6.5 2 12 2a10 10 0 0 1 8 4"/><path d="M5 19.5C5.5 18 6 15 6 12c0-3.5 2.5-6 6-6 2 0 4 1 5 2.5"/><path d="M12 12c0 4-1 8-3 10"/><path d="M12 12c0 3 .5 6 2 8"/><path d="M18 12c0 2-.5 4-1 6"/></>}

  {/* Schedulers */}
  {name === "clock" && <><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></>}
  {name === "calendar" && <><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M3 10h18M8 2v4M16 2v4"/></>}
  {name === "timer" && <><circle cx="12" cy="13" r="8"/><path d="M12 9v4l2 2M5 3 2 6M22 6l-3-3"/><path d="M12 5V3"/></>}

  {/* General */}
  {name === "check" && <><path d="M20 6 9 17l-5-5"/></>}
  {name === "x" && <><path d="M18 6 6 18M6 6l12 12"/></>}
  {name === "minus" && <><path d="M5 12h14"/></>}
  {name === "arrow-right" && <><path d="M5 12h14M12 5l7 7-7 7"/></>}
  {name === "external" && <><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><path d="M15 3h6v6"/><path d="M10 14 21 3"/></>}
  {name === "github" && <><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.4 5.4 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65S8.93 17.38 9 18v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></>}
  {name === "sun" && <><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></>}
  {name === "moon" && <><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></>}
  {name === "server" && <><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><path d="M6 6h.01M6 18h.01"/></>}
  {name === "database" && <><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/><path d="M3 12c0 1.66 4 3 9 3s9-1.34 9-3"/></>}
  {name === "terminal" && <><rect x="2" y="3" width="20" height="18" rx="2"/><path d="m7 9 3 3-3 3M13 15h4"/></>}
  {name === "globe" && <><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></>}
</svg>
